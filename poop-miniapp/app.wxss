page { --bg: #f5f5f0; --card: #fff; --text: #333; --sub: #888; --accent: #6b8e4e; --accent2: #e07b5a; --border: #e8e8e0; }

.theme-dark { --bg: #1a1a2e; --card: #252540; --text: #ddd; --sub: #999; --accent: #8bc34a; --accent2: #ff8a65; --border: #333; }

page { background:var(--bg); color:var(--text); font-family:-apple-system,'PingFang SC','Helvetica Neue',sans-serif; }

.card { background:var(--card); border-radius:16rpx; padding:30rpx; margin:20rpx; box-shadow:0 2rpx 16rpx rgba(0,0,0,0.06); }

.btn-primary { background:var(--accent); color:#fff; border-radius:40rpx; padding:18rpx 50rpx; font-size:30rpx; border:none; }

.btn-secondary { background:var(--card); color:var(--accent); border:2rpx solid var(--accent); border-radius:40rpx; padding:18rpx 50rpx; font-size:30rpx; }

button[disabled] { opacity:0.4; }

.container { padding:20rpx 0; }
