/* ========== 空状态 ========== */
.empty-state { text-align:center; padding:120rpx 40rpx 80rpx; }
.empty-badge { font-size:110rpx; margin-bottom:28rpx; animation: breathe 3.5s ease-in-out infinite; }
.empty-title { font-size:34rpx; font-weight:700; color:var(--text); margin-bottom:14rpx; }
.empty-sub { font-size:26rpx; color:var(--sub2); }

/* ========== 段位卡片 ========== */
.tier-card {
  display:flex; align-items:center; gap:28rpx;
  margin:20rpx 22rpx; padding:36rpx 34rpx;
  background: linear-gradient(135deg, var(--card) 0%, var(--card2) 100%);
  border-radius: var(--radius-lg); box-shadow: var(--shadow-md);
  border: 1rpx solid var(--border-light);
  border-left: 4rpx solid var(--accent4);
  animation: bounceInUp 0.55s var(--ease-spring);
  position: relative;
  overflow: hidden;
}
.tier-card::before {
  content: '';
  position: absolute;
  top: -40%; right: -10%;
  width: 200rpx; height: 200rpx;
  background: radial-gradient(circle, rgba(212,168,74,0.08) 0%, transparent 70%);
  pointer-events: none;
}
.theme-dark .tier-card { border-color: var(--border); }
.tier-badge-wrap { position:relative; flex-shrink: 0; }
.tier-glow {
  width:120rpx; height:120rpx; border-radius:50%;
  background: radial-gradient(circle, rgba(212,168,74,0.15) 0%, transparent 70%);
  position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
  animation: breathe 2.5s ease-in-out infinite;
}
.tier-icon { font-size:78rpx; position:relative; z-index:1; }
.tier-info { flex:1; }
.tier-name { font-size:34rpx; font-weight:800; color:var(--text); margin-bottom:14rpx; }
.tier-bar-wrap { height:10rpx; background:var(--border-light); border-radius:5rpx; margin-bottom:12rpx; overflow:hidden; }
.tier-bar {
  height:100%;
  background: linear-gradient(90deg, var(--accent4), var(--accent2));
  border-radius:5rpx;
  animation: progressFill 1s var(--ease-out);
  min-width:6rpx;
}
.tier-hint { font-size:24rpx; color:var(--sub); }
.tier-hint.max { color:var(--accent4); font-weight:700; }
.tier-highlight { color:var(--accent2); font-weight:700; }

/* ========== 便便博物馆 ========== */
.title-sub { font-size:24rpx; color:var(--sub2); font-weight:400; margin-left:10rpx; }
.museum-grid {
  display:grid;
  grid-template-columns: repeat(4, 1fr);
  gap:14rpx;
}
.museum-cell {
  display: flex; flex-direction: column; align-items: center;
  text-align:center; padding:20rpx 8rpx 16rpx;
  border-radius: var(--radius-lg); background: var(--card2);
  border: 2rpx solid var(--border-light);
  transition: all var(--duration-normal) var(--ease-spring);
  position: relative;
  overflow: hidden;
}
.museum-cell::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, var(--border-mid) 50%, transparent 100%);
  opacity: 0;
  transition: opacity var(--duration-normal);
}
.museum-cell.collected {
  border-color: var(--accent);
  background: rgba(74,124,89,0.05);
  animation: bounceIn 0.5s var(--ease-spring);
}
.museum-cell.collected::before { opacity: 1; }
.museum-cell:not(.collected) { opacity: 0.45; }
.museum-cell:active { transform: scale(0.94); }
.museum-icon { font-size:52rpx; margin-bottom:8rpx; }
.museum-name { font-size:20rpx; font-weight:700; color:var(--text); }
.museum-desc { font-size:18rpx; color:var(--sub2); margin-top:4rpx; line-height:1.3; }

/* ========== 分类标签 ========== */
.category-tabs { display:flex; gap:12rpx; margin-bottom:28rpx; flex-wrap:wrap; }
.cat-tab {
  padding:12rpx 28rpx; border-radius: var(--radius-full);
  font-size:26rpx; color:var(--sub); background:var(--card2);
  transition: all var(--duration-fast) var(--ease-spring);
  font-weight:500;
  border: 1.5rpx solid var(--border);
}
.cat-tab.active {
  background: linear-gradient(135deg, var(--accent), var(--accent-dark));
  color:#fff; font-weight:600;
  box-shadow: 0 4rpx 16rpx rgba(74,124,89,0.22);
  transform: scale(1.03);
  border-color: transparent;
}
.cat-tab:not(.active):active { transform: scale(0.95); background: var(--border-light); }

/* ========== 成就网格 ========== */
.achievement-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap:16rpx;
}
.ach-cell {
  position:relative;
  display: flex; flex-direction: column; align-items: center;
  text-align:center; padding:28rpx 14rpx 22rpx;
  border-radius: var(--radius-lg);
  transition: all var(--duration-normal) var(--ease-spring);
  overflow: hidden;
  background: var(--card2);
  border: 1.5rpx solid var(--border-light);
}
.ach-cell.unlocked {
  background: linear-gradient(145deg, var(--card) 0%, #faf5e0 100%);
  border: 1.5rpx solid var(--accent4);
  box-shadow: var(--shadow-sm);
}
.ach-cell.unlocked::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; height: 3rpx;
  background: linear-gradient(90deg, var(--accent4), var(--accent2), var(--accent4));
  background-size: 200% 100%;
  animation: shimmerGold 3s linear infinite;
}
@keyframes shimmerGold {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
.ach-cell.locked {
  background: var(--card2);
  opacity: 0.50;
  border: 1.5rpx solid transparent;
}
.ach-cell:active { transform: scale(0.94); }

.ach-icon-wrap {
  width:90rpx; height:90rpx; border-radius:50%;
  background: var(--card);
  display: flex; align-items: center; justify-content: center;
  font-size:50rpx;
  margin-bottom:14rpx;
  box-shadow: var(--shadow-sm);
  transition: all var(--duration-normal);
  border: 1rpx solid var(--border-light);
}
.ach-cell.unlocked .ach-icon-wrap {
  box-shadow: 0 0 0 10rpx rgba(212,168,74,0.08), var(--shadow-sm);
}
.ach-cell.unlocked .ach-icon {
  animation: breathe 2.8s ease-in-out infinite;
}
.ach-name {
  font-size:26rpx; font-weight:700; color:var(--text);
  margin-bottom:6rpx; text-align:center;
  padding: 0 4rpx;
}
.ach-desc {
  font-size:22rpx; color:var(--sub2);
  line-height:1.5; text-align:center;
  padding: 0 4rpx;
}
.ach-glow {
  position:absolute; top:-24rpx; left:50%; transform:translateX(-50%);
  width:82rpx; height:44rpx; border-radius:50%;
  background: radial-gradient(circle, rgba(212,168,74,0.10) 0%, transparent 70%);
  animation: breathe 2.2s ease-in-out infinite;
}

/* 进度条 */
.ach-progress-wrap {
  height:6rpx; background:var(--border-light); border-radius:3rpx;
  margin-top:12rpx; overflow:hidden;
  width: 100%;
}
.ach-progress-bar {
  height:100%;
  background: linear-gradient(90deg, var(--accent), var(--accent-light));
  border-radius:3rpx;
  animation: progressFill 0.7s var(--ease-out);
  min-width:3rpx;
}