/* ========== 空状态 ========== */
.empty-state { text-align:center; padding:100rpx 40rpx 60rpx; }
.empty-badge { font-size:100rpx; margin-bottom:24rpx; filter:grayscale(0.3); }
.empty-title { font-size:32rpx; font-weight:600; color:var(--text); margin-bottom:12rpx; }
.empty-sub { font-size:26rpx; color:var(--sub2); }

/* ========== 段位卡片 ========== */
.tier-card {
  display:flex; align-items:center; gap:24rpx;
  margin:16rpx 20rpx; padding:32rpx 30rpx;
  background:linear-gradient(135deg, #fafdf6, #f2f7ea, #fafdf6);
  border-radius:var(--radius-lg); box-shadow:var(--shadow-md);
}
.theme-dark .tier-card {
  background:linear-gradient(135deg, #1e2418, #1a2016, #1e2218);
}
.tier-badge-wrap { position:relative; }
.tier-glow {
  width:100rpx; height:100rpx; border-radius:50%;
  background:radial-gradient(circle, rgba(107,142,78,0.12) 0%, transparent 70%);
  position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
}
.tier-icon { font-size:64rpx; position:relative; z-index:1; }
.tier-info { flex:1; }
.tier-name { font-size:34rpx; font-weight:800; color:var(--text); margin-bottom:12rpx; }
.tier-bar-wrap { height:8rpx; background:var(--border-light); border-radius:4rpx; margin-bottom:10rpx; overflow:hidden; }
.tier-bar { height:100%; background:linear-gradient(90deg, var(--accent-light), var(--accent), #4a7a2e); border-radius:4rpx; transition:width 0.6s ease-out; min-width:6rpx; }
.tier-hint { font-size:24rpx; color:var(--sub); }
.tier-hint.max { color:var(--accent); font-weight:600; }
.tier-highlight { color:var(--accent); font-weight:700; }

/* ========== 便便博物馆 ========== */
.title-sub { font-size:24rpx; color:var(--sub2); font-weight:400; margin-left:8rpx; }
.museum-grid { display:grid; grid-template-columns:repeat(4, 1fr); gap:12rpx; }
.museum-cell {
  text-align:center; padding:18rpx 8rpx 14rpx;
  border-radius:var(--radius-sm); background:var(--card2);
  border:1rpx solid var(--border-light);
  transition:all 0.2s;
}
.museum-cell.collected { background:rgba(107,142,78,0.05); border-color:rgba(107,142,78,0.15); }
.museum-icon { font-size:36rpx; margin-bottom:6rpx; }
.museum-name { font-size:20rpx; font-weight:600; color:var(--text); }
.museum-desc { font-size:18rpx; color:var(--sub2); margin-top:2rpx; line-height:1.3; }

/* ========== 里程碑 ========== */
.milestone-card {
  position:relative; text-align:center; margin:16rpx 20rpx; padding:36rpx;
  background:linear-gradient(135deg, #fffbe6, #fff8d6, #fff3c4);
  border-radius:var(--radius-lg); overflow:hidden;
}
.theme-dark .milestone-card {
  background:linear-gradient(135deg, #2a2818, #2a2410, #2e2618);
}
.milestone-glow {
  position:absolute; top:-40rpx; left:50%; transform:translateX(-50%);
  width:200rpx; height:80rpx; border-radius:50%;
  background:radial-gradient(circle, rgba(255,200,0,0.15) 0%, transparent 70%);
}
.milestone-icon { font-size:64rpx; position:relative; z-index:1; }
.milestone-msg { font-size:30rpx; font-weight:700; color:#b8860b; margin-top:12rpx; position:relative; z-index:1; }
.theme-dark .milestone-msg { color:#d4a84a; }

/* ========== 分类标签 ========== */
.category-tabs { display:flex; gap:12rpx; margin-bottom:24rpx; }
.cat-tab {
  padding:10rpx 24rpx; border-radius:var(--radius-full);
  font-size:24rpx; color:var(--sub); background:var(--card2);
  transition:all 0.2s;
}
.cat-tab.active { background:var(--accent); color:#fff; font-weight:600; }

/* ========== 成就网格 ========== */
.achievement-grid { display:flex; flex-wrap:wrap; gap:16rpx; }
.ach-cell {
  position:relative; width:calc(33.33% - 11rpx);
  text-align:center; padding:22rpx 10rpx 18rpx;
  border-radius:var(--radius-md); overflow:hidden;
  transition:all 0.3s;
}
.ach-cell.unlocked { background:rgba(107,142,78,0.05); }
.ach-cell.locked { background:var(--border-light); opacity:0.6; }
.ach-icon-wrap { margin-bottom:8rpx; }
.ach-icon { font-size:40rpx; }
.ach-name { font-size:22rpx; font-weight:600; color:var(--text); margin-bottom:4rpx; }
.ach-desc { font-size:18rpx; color:var(--sub2); line-height:1.4; }
.ach-glow {
  position:absolute; top:-20rpx; left:50%; transform:translateX(-50%);
  width:80rpx; height:40rpx; border-radius:50%;
  background:radial-gradient(circle, rgba(107,142,78,0.1) 0%, transparent 70%);
}

/* 进度条 */
.ach-progress-wrap {
  height:4rpx; background:var(--border-light); border-radius:2rpx;
  margin-top:10rpx; overflow:hidden;
}
.ach-progress-bar {
  height:100%; background:var(--accent); border-radius:2rpx;
  transition:width 0.4s ease-out; min-width:3rpx;
}

/* ========== 累计统计 ========== */
.total-stats { display:flex; justify-content:space-around; text-align:center; }
.total-item { display:flex; flex-direction:column; align-items:center; gap:8rpx; }
.total-ring {
  width:110rpx; height:110rpx; border-radius:50%;
  background:var(--card2); display:flex; align-items:center; justify-content:center;
  font-size:36rpx; font-weight:800; color:var(--accent);
  box-shadow:inset 0 0 0 3rpx var(--border-light);
}
.total-unit { font-size:24rpx; font-weight:400; margin-left:2rpx; }
.total-label { font-size:24rpx; color:var(--sub2); }

/* ========== 快捷入口 ========== */
.quick-links { display:flex; gap:16rpx; padding:0 20rpx; margin-top:20rpx; }
.link-btn {
  flex:1; text-align:center; background:var(--card); border-radius:var(--radius-md);
  padding:28rpx 16rpx; box-shadow:var(--shadow-sm);
  display:flex; flex-direction:column; align-items:center; gap:10rpx;
  transition:all 0.15s;
}
.link-btn-hover { transform:translateY(2rpx); }
.link-icon { font-size:40rpx; }
.link-label { font-size:26rpx; color:var(--text); font-weight:500; }
