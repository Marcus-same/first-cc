/* ========== 空状态 ========== */
.empty-state { text-align:center; padding:100rpx 40rpx 60rpx; }
.empty-badge { font-size:100rpx; margin-bottom:24rpx; filter:grayscale(0.3); }
.empty-title { font-size:32rpx; font-weight:700; color:var(--text); margin-bottom:12rpx; }
.empty-sub { font-size:26rpx; color:var(--sub2); }

/* ========== 段位卡片 ========== */
.tier-card {
  display:flex; align-items:center; gap:24rpx;
  margin:16rpx 20rpx; padding:32rpx 30rpx;
  background:linear-gradient(135deg, #fafff5, #f0fae8, #f5fff0);
  border-radius:var(--radius-lg); box-shadow:var(--shadow-md);
  border:1rpx solid rgba(126,200,80,0.08);
}
.theme-dark .tier-card {
  background:linear-gradient(135deg, #1e2418, #1a2016, #1e2218);
}
.tier-badge-wrap { position:relative; }
.tier-glow {
  width:110rpx; height:110rpx; border-radius:50%;
  background:radial-gradient(circle, rgba(126,200,80,0.12) 0%, transparent 70%);
  position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
}
.tier-icon { font-size:72rpx; position:relative; z-index:1; }
.tier-info { flex:1; }
.tier-name { font-size:34rpx; font-weight:800; color:var(--text); margin-bottom:12rpx; }
.tier-bar-wrap { height:10rpx; background:var(--border-light); border-radius:5rpx; margin-bottom:10rpx; overflow:hidden; }
.tier-bar { height:100%; background:linear-gradient(90deg, var(--accent-light), var(--accent), var(--accent-dark)); border-radius:5rpx; transition:width 0.6s ease-out; min-width:6rpx; }
.tier-hint { font-size:24rpx; color:var(--sub); }
.tier-hint.max { color:var(--accent); font-weight:700; }
.tier-highlight { color:var(--accent); font-weight:700; }

/* ========== 便便博物馆 ========== */
.title-sub { font-size:24rpx; color:var(--sub2); font-weight:400; margin-left:8rpx; }
.museum-grid { display:grid; grid-template-columns:repeat(3, 1fr); gap:12rpx; }
.museum-cell {
  text-align:center; padding:18rpx 8rpx 14rpx;
  border-radius:var(--radius-md); background:var(--card2);
  border:1rpx solid var(--border-light);
  transition:all 0.3s;
}
.museum-cell.collected { background:rgba(126,200,80,0.06); border-color:rgba(126,200,80,0.18); }
.museum-icon { font-size:40rpx; margin-bottom:6rpx; }
.museum-name { font-size:20rpx; font-weight:600; color:var(--text); }
.museum-desc { font-size:18rpx; color:var(--sub2); margin-top:2rpx; line-height:1.3; }

/* ========== 分类标签 ========== */
.category-tabs { display:flex; gap:12rpx; margin-bottom:24rpx; }
.cat-tab {
  padding:12rpx 28rpx; border-radius:var(--radius-full);
  font-size:26rpx; color:var(--sub); background:var(--card2);
  transition:all 0.2s;
  font-weight:500;
}
.cat-tab.active { background:linear-gradient(135deg, var(--accent), var(--accent-dark)); color:#fff; font-weight:600; box-shadow:0 4rpx 12rpx rgba(126,200,80,0.25); }

/* ========== 成就网格 ========== */
.achievement-grid { display:flex; flex-wrap:wrap; justify-content:center; gap:16rpx; }
.ach-cell {
  position:relative; width:calc(33.33% - 11rpx);
  text-align:center; padding:24rpx 10rpx 18rpx;
  border-radius:var(--radius-md); overflow:hidden;
  transition:all 0.3s;
}
.ach-cell.unlocked { background:rgba(126,200,80,0.05); border:1rpx solid rgba(126,200,80,0.10); }
.ach-cell.locked { background:var(--card2); opacity:0.55; border:1rpx solid transparent; }
.ach-icon-wrap { margin-bottom:8rpx; }
.ach-icon { font-size:44rpx; }
.ach-name { font-size:22rpx; font-weight:700; color:var(--text); margin-bottom:4rpx; }
.ach-desc { font-size:18rpx; color:var(--sub2); line-height:1.4; }
.ach-glow {
  position:absolute; top:-20rpx; left:50%; transform:translateX(-50%);
  width:80rpx; height:40rpx; border-radius:50%;
  background:radial-gradient(circle, rgba(126,200,80,0.10) 0%, transparent 70%);
}

/* 进度条 */
.ach-progress-wrap {
  height:6rpx; background:var(--border-light); border-radius:3rpx;
  margin-top:10rpx; overflow:hidden;
}
.ach-progress-bar {
  height:100%; background:linear-gradient(90deg, var(--accent), var(--accent-light)); border-radius:3rpx;
  transition:width 0.4s ease-out; min-width:3rpx;
}
