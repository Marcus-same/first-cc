/* ========== 周报头部 ========== */
.report-header { text-align:center; padding:40rpx 40rpx 28rpx; }
.report-icon { font-size:64rpx; margin-bottom:12rpx; }
.report-title { font-size:38rpx; font-weight:800; color:var(--text); }
.report-range { font-size:26rpx; color:var(--sub2); margin-top:8rpx; }

/* ========== 概览 ========== */
.overview-grid { display:flex; flex-wrap:wrap; gap:8rpx 0; }
.ov-item { width:50%; text-align:center; padding:20rpx 0; }
.ov-num { font-size:52rpx; font-weight:800; }
.ov-num.accent { color:var(--accent); }
.ov-num.accent2 { color:var(--accent2); }
.ov-num.accent3 { color:var(--accent3); }
.ov-num.accent4 { color:var(--accent4); }
.ov-unit { font-size:28rpx; font-weight:400; }
.ov-label { font-size:24rpx; color:var(--sub2); margin-top:4rpx; }

/* ========== 每日趋势柱状图 ========== */
.bar-chart { display:flex; justify-content:space-around; align-items:flex-end; height:220rpx; padding-top:10rpx; }
.bar-col { display:flex; flex-direction:column; align-items:center; width:52rpx; }
.bar-val { font-size:22rpx; color:var(--sub); margin-bottom:6rpx; font-weight:600; }
.bar-fill {
  width:36rpx; min-height:6rpx;
  background:var(--border); border-radius:8rpx 8rpx 0 0;
  transition:height 0.5s ease-out;
}
.bar-fill.mid { background:linear-gradient(180deg, #8cba6a, #6b8e4e); }
.bar-fill.high { background:linear-gradient(180deg, #7ba65a, #4a7a2e); }
.bar-label { font-size:20rpx; color:var(--sub2); margin-top:10rpx; white-space:nowrap; }

/* ========== 类型分布 ========== */
.type-list { }
.type-row { display:flex; align-items:center; gap:14rpx; margin-bottom:16rpx; }
.type-emoji { font-size:36rpx; width:50rpx; text-align:center; }
.type-bar-wrap { flex:1; height:22rpx; background:var(--border-light); border-radius:11rpx; overflow:hidden; }
.type-bar { height:100%; border-radius:11rpx; transition:width 0.6s ease-out; min-width:4rpx; }
.type-pct { font-size:24rpx; color:var(--sub); width:56rpx; text-align:right; font-weight:600; }
.type-empty { text-align:center; color:var(--sub2); padding:30rpx; font-size:26rpx; }

/* ========== 健康提醒 ========== */
.alerts-section { margin:16rpx 20rpx; }
.alerts-header { font-size:30rpx; font-weight:600; margin-bottom:16rpx; padding-left:4rpx; }
.alert-item { display:flex; gap:14rpx; padding:18rpx 20rpx; border-radius:var(--radius-md); margin-bottom:12rpx; align-items:flex-start; }
.alert-item.danger { background:rgba(224,123,90,0.08); border-left:4rpx solid var(--accent2); }
.alert-item.warn { background:rgba(240,180,60,0.08); border-left:4rpx solid var(--accent4); }
.alert-item.info { background:rgba(100,150,200,0.08); border-left:4rpx solid var(--accent3); }
.alert-dot { width:10rpx; height:10rpx; border-radius:50%; margin-top:10rpx; flex-shrink:0; }
.alert-dot.danger { background:var(--accent2); }
.alert-dot.warn { background:var(--accent4); }
.alert-dot.info { background:var(--accent3); }
.alert-text { font-size:26rpx; color:var(--text); flex:1; line-height:1.7; }

/* ========== 建议 ========== */
.advice-card { margin:0 20rpx 16rpx; padding:24rpx 28rpx; background:var(--card); border-radius:var(--radius-md); box-shadow:var(--shadow-sm); }
.advice-header { font-size:30rpx; font-weight:600; margin-bottom:14rpx; color:var(--text); }
.advice-body { font-size:28rpx; color:var(--sub); line-height:1.8; }

/* ========== 分享按钮 ========== */
.share-actions { display:flex; gap:20rpx; padding:8rpx 20rpx 40rpx; }
.btn-share { flex:1; background:var(--accent); color:#fff; border-radius:var(--radius-full); padding:22rpx; font-size:28rpx; font-weight:600; border:none; box-shadow:0 4rpx 16rpx rgba(107,142,78,0.25); }
.btn-share:active { transform:scale(0.97); }
.btn-save { flex:1; background:var(--card); color:var(--accent); border-radius:var(--radius-full); padding:22rpx; font-size:28rpx; font-weight:600; border:2rpx solid var(--accent); }
.btn-save:active { background:rgba(107,142,78,0.05); }
