/* ========== 完成头部 ========== */
.done-header {
  display:flex; align-items:center; gap:24rpx;
  padding:32rpx 36rpx; margin:16rpx 20rpx;
  background:linear-gradient(135deg, #fafff5, #f0fae8);
  border-radius:var(--radius-lg);
  border:1rpx solid rgba(126,200,80,0.08);
}
.theme-dark .done-header {
  background:linear-gradient(135deg, #1e2818, #1a2418);
}
.done-icon { font-size:56rpx; }
.done-title { font-size:34rpx; font-weight:700; color:var(--text); }
.done-time { font-size:26rpx; color:var(--sub); margin-top:4rpx; }

/* ========== Bristol 双列网格 ========== */
.bristol-grid {
  display:grid; grid-template-columns:1fr 1fr; gap:14rpx;
  justify-items:center;
}
.bristol-cell { width:100%; }
.bristol-cell {
  position:relative;
  padding:22rpx 16rpx 18rpx; border-radius:var(--radius-md);
  border:2rpx solid var(--border-light);
  text-align:center;
  transition:all 0.2s;
  background:var(--card2);
}
.bristol-cell.selected {
  border-color:var(--accent);
  background:rgba(126,200,80,0.06);
  box-shadow:0 0 0 4rpx rgba(126,200,80,0.06);
}
.theme-dark .bristol-cell.selected {
  background:rgba(139,195,74,0.08);
  box-shadow:0 0 0 4rpx rgba(139,195,74,0.06);
}
.bristol-emoji { font-size:52rpx; margin-bottom:8rpx; }
.bristol-name { font-size:26rpx; font-weight:700; color:var(--text); margin-bottom:4rpx; }
.bristol-desc { font-size:20rpx; color:var(--sub2); line-height:1.4; }
.bristol-check {
  position:absolute; top:-8rpx; right:-8rpx;
  width:36rpx; height:36rpx; border-radius:50%;
  background:linear-gradient(135deg, var(--accent), var(--accent-dark)); color:#fff; font-size:22rpx;
  display:flex; align-items:center; justify-content:center;
  font-weight:bold;
  box-shadow:0 2rpx 8rpx rgba(126,200,80,0.25);
}

/* ========== 建议卡片 ========== */
.advice-card {
  display:flex; gap:16rpx; align-items:flex-start;
  margin:0 20rpx 16rpx; padding:20rpx 24rpx;
  background:rgba(126,200,80,0.05); border-radius:var(--radius-md);
  border-left:6rpx solid var(--accent);
}
.advice-dot { width:8rpx; height:8rpx; border-radius:50%; background:var(--accent); margin-top:14rpx; flex-shrink:0; }
.advice-text { font-size:26rpx; color:var(--sub); line-height:1.8; flex:1; }

/* ========== 备注 ========== */
.optional { font-size:24rpx; color:var(--sub2); font-weight:400; }
.note-input {
  width:100%; min-height:120rpx; font-size:28rpx; color:var(--text);
  padding:16rpx; border-radius:var(--radius-sm);
  background:var(--bg); border:1rpx solid var(--border-light);
}
.note-counter { text-align:right; font-size:22rpx; color:var(--sub2); margin-top:8rpx; }

/* ========== 位置设置 ========== */
.setting-row { display:flex; justify-content:space-between; align-items:center; }
.setting-left { display:flex; align-items:center; gap:14rpx; }
.setting-icon { font-size:36rpx; }
.setting-label { font-size:28rpx; color:var(--text); }
.location-detail {
  display:flex; align-items:center; gap:10rpx;
  margin-top:14rpx; padding:14rpx 18rpx;
  background:rgba(126,200,80,0.06); border-radius:var(--radius-sm);
  font-size:26rpx; color:var(--accent);
}
.location-detail.dim { color:var(--sub2); }
.loc-dot { width:10rpx; height:10rpx; border-radius:50%; background:var(--accent); }

/* ========== 按钮 ========== */
.save-row { display:flex; gap:20rpx; padding:8rpx 20rpx 40rpx; }
.btn-skip {
  flex:1; background:var(--card); color:var(--sub); border-radius:var(--radius-full);
  padding:22rpx; font-size:30rpx; border:1rpx solid var(--border);
  transition:all 0.15s;
  font-weight:500;
}
.btn-skip:active { background:var(--border-light); transform:scale(0.97); }
.btn-save {
  flex:2; background:linear-gradient(135deg, var(--accent), var(--accent-dark)); color:#fff; border-radius:var(--radius-full);
  padding:22rpx; font-size:30rpx; font-weight:600; border:none;
  box-shadow:0 6rpx 20rpx rgba(126,200,80,0.30);
  transition:all 0.15s;
}
.btn-save:active { transform:scale(0.95); box-shadow:0 3rpx 10rpx rgba(126,200,80,0.2); }
