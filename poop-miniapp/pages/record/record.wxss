/* ========== 完成头部 ========== */
.done-header {
  display:flex; align-items:center; gap:28rpx;
  padding:36rpx 40rpx; margin:20rpx 22rpx;
  background: var(--card);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border-light);
  border-left: 4rpx solid var(--accent);
  box-shadow: var(--shadow-md);
  animation: bounceInUp 0.55s var(--ease-spring);
  position: relative;
  overflow: hidden;
}
.done-header::before {
  content: '';
  position: absolute;
  top: -40%; right: -10%;
  width: 160rpx; height: 160rpx;
  background: radial-gradient(circle, rgba(74,124,89,0.06) 0%, transparent 70%);
  pointer-events: none;
}
.theme-dark .done-header { border-color: var(--border); }
.done-icon {
  font-size:60rpx;
  animation: checkPop 0.5s var(--ease-spring) 0.2s both;
  flex-shrink: 0;
}
.done-title { font-size:34rpx; font-weight:700; color:var(--text); }
.done-time { font-size:26rpx; color:var(--sub); margin-top:6rpx; }

/* ========== Bristol 横向滚动卡片 ========== */
.bristol-scroll {
  width: 100%;
  white-space: nowrap;
  overflow: visible;
}
.bristol-track {
  display: inline-flex;
  gap: 16rpx;
  padding: 10rpx 6rpx;
  align-items: stretch;
}
.bristol-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 164rpx;
  min-height: 184rpx;
  padding: 26rpx 14rpx 22rpx;
  border-radius: var(--radius-lg);
  border: 2.5rpx solid var(--border-light);
  background: var(--card2);
  transition: all var(--duration-normal) var(--ease-spring);
  position: relative;
  white-space: normal;
}
.bristol-card.selected {
  border-color: var(--accent);
  background: rgba(74,124,89,0.06);
  transform: scale(1.06);
  box-shadow: var(--shadow-glow);
}
.bristol-card:active { transform: scale(0.97); }
.theme-dark .bristol-card.selected { background: rgba(90,148,104,0.10); }
.bristol-emoji { font-size:68rpx; margin-bottom:12rpx; filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.08)); }
.bristol-name { font-size:24rpx; font-weight:700; color:var(--text); text-align:center; line-height:1.3; margin-bottom:8rpx; }
.bristol-type-num { font-size:20rpx; color:var(--sub2); }
.bristol-check-icon {
  position:absolute; top:-12rpx; right:-12rpx;
  width:44rpx; height:44rpx; border-radius:50%;
  background: linear-gradient(135deg, var(--accent), var(--accent-dark));
  color:#fff; font-size:26rpx;
  display:flex; align-items:center; justify-content:center;
  font-weight:bold;
  box-shadow: 0 4rpx 14rpx rgba(74,124,89,0.30);
  animation: bounceIn 0.4s var(--ease-spring);
}
.optional { font-size:24rpx; color:var(--sub2); font-weight:400; }

/* ========== 建议卡片 ========== */
.advice-card {
  display:flex; gap:16rpx; align-items:flex-start;
  margin:0 22rpx 20rpx; padding:22rpx 28rpx;
  background: var(--card); border-radius:var(--radius-md);
  border: 1rpx solid var(--border-light);
  border-left: 5rpx solid var(--accent);
  box-shadow: var(--shadow-sm);
  animation: fadeInUp var(--duration-normal) var(--ease-out);
}
.advice-dot { width:10rpx; height:10rpx; border-radius:50%; background:var(--accent); margin-top:14rpx; flex-shrink:0; }
.advice-text { font-size:26rpx; color:var(--sub); line-height:1.8; flex:1; }

/* ========== 备注 ========== */
.note-input {
  width:100%; min-height:120rpx; font-size:28rpx; color:var(--text);
  padding:16rpx; border-radius:var(--radius-sm);
  background:var(--card2); border:2rpx solid var(--border-light);
  transition: border-color var(--duration-fast);
  resize: none;
  font-family: var(--font-body);
}
.note-input:focus { border-color: var(--accent); box-shadow: 0 0 0 4rpx rgba(74,124,89,0.08); }
.note-counter { text-align:right; font-size:22rpx; color:var(--sub2); margin-top:8rpx; }

/* ========== 位置设置 ========== */
.setting-row { display:flex; justify-content:space-between; align-items:center; }
.setting-left { display:flex; align-items:center; gap:16rpx; }
.setting-icon { font-size:36rpx; }
.setting-label { font-size:28rpx; color:var(--text); font-weight: 500; }
.location-detail {
  display:flex; align-items:center; gap:12rpx;
  margin-top:16rpx; padding:16rpx 20rpx;
  background:rgba(74,124,89,0.06); border-radius:var(--radius-sm);
  font-size:26rpx; color:var(--accent);
  animation: fadeInUp var(--duration-fast) var(--ease-out);
  border: 1rpx solid rgba(74,124,89,0.10);
}
.location-detail.dim { color:var(--sub2); background: var(--card2); border-color: var(--border-light); }
.loc-dot { width:10rpx; height:10rpx; border-radius:50%; background:var(--accent); }

/* ========== 按钮 ========== */
.save-row { display:flex; gap:20rpx; padding:12rpx 22rpx 48rpx; }
.btn-skip {
  flex:1; background:var(--card); color:var(--sub); border-radius:var(--radius-full);
  padding:24rpx; font-size:30rpx; border:2rpx solid var(--border);
  transition: all var(--duration-fast) var(--ease-spring);
  font-weight:500;
  box-shadow: var(--shadow-sm);
}
.btn-skip:active { background:var(--border-light); transform:scale(0.97); }
.btn-save {
  flex:2; background: linear-gradient(135deg, var(--accent), var(--accent-dark));
  color:#fff; border-radius:var(--radius-full);
  padding:24rpx; font-size:30rpx; font-weight:600; border:none;
  box-shadow: 0 6rpx 24rpx rgba(74,124,89,0.28);
  transition: all var(--duration-fast) var(--ease-spring);
  display: flex; align-items: center; justify-content: center;
  letter-spacing: 1rpx;
}
.btn-save.ready { animation: pulseGlow 2.2s ease-in-out infinite; }
@keyframes pulseGlow {
  0%, 100% { box-shadow: 0 6rpx 24rpx rgba(74,124,89,0.28); }
  50% { box-shadow: 0 6rpx 36rpx rgba(74,124,89,0.48); }
}
.btn-save:active { transform:scale(0.95); box-shadow: 0 3rpx 12rpx rgba(74,124,89,0.20); }