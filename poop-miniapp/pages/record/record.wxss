.container { min-height:100vh; padding-bottom:40rpx; }
.header { display:flex; align-items:center; gap:24rpx; padding:36rpx; }
.header-icon { font-size:72rpx; }
.header-title { font-size:36rpx; font-weight:bold; }
.header-time { font-size:28rpx; color:var(--sub); margin-top:4rpx; }
.section-title { font-size:30rpx; font-weight:bold; margin-bottom:20rpx; }
.bristol-grid { display:flex; flex-direction:column; gap:12rpx; }
.bristol-item { display:flex; align-items:center; gap:16rpx; padding:20rpx 16rpx; border-radius:12rpx; border:2rpx solid var(--border); transition:.2s; }
.bristol-item.selected { border-color:var(--accent); background:rgba(107,142,78,0.08); }
.bristol-icon { font-size:44rpx; width:60rpx; text-align:center; }
.bristol-name { font-size:28rpx; font-weight:bold; min-width:220rpx; }
.bristol-desc { font-size:24rpx; color:var(--sub); flex:1; text-align:right; }
.advice { display:flex; gap:16rpx; }
.advice-icon { font-size:40rpx; }
.advice-text { font-size:28rpx; color:var(--sub); line-height:1.7; }
.save-row { display:flex; gap:20rpx; padding:20rpx; }
.btn-skip { flex:1; background:var(--card); color:var(--sub); border-radius:40rpx; padding:20rpx; font-size:30rpx; border:none; }
.btn-save { flex:2; background:var(--accent); color:#fff; border-radius:40rpx; padding:20rpx; font-size:30rpx; border:none; }
.note-input { width:100%; min-height:120rpx; font-size:28rpx; color:var(--text); padding:12rpx 0; }
.note-placeholder { color:#bbb; }
.setting-row { display:flex; justify-content:space-between; align-items:center; }
.setting-label { font-size:28rpx; color:var(--text); }
.location-info { font-size:24rpx; color:var(--accent); margin-top:12rpx; }
