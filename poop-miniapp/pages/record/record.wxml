<view class="container {{dark ? 'theme-dark' : ''}}">
  <!-- 完成头部 -->
  <view class="done-header fade-in bounce-in-up">
    <view class="done-icon">✅</view>
    <view class="done-info">
      <view class="done-title">记录完成！</view>
      <view class="done-time">⏱ 用时 {{min}}分{{sec}}秒</view>
    </view>
  </view>

  <!-- 布里斯托类型选择 - 横向滑动 -->
  <view class="card fade-in-1">
    <view class="section-title">🥑 选择布里斯托类型 <text class="optional">(滑动选择)</text></view>
    <scroll-view class="bristol-scroll" scroll-x enable-flex>
      <view class="bristol-track">
        <view
          class="bristol-card {{selectedType === item.type ? 'selected' : ''}}"
          wx:for="{{bristol}}" wx:key="type"
          bindtap="selectType" data-type="{{item.type}}"
        >
          <view class="bristol-emoji">{{item.icon}}</view>
          <view class="bristol-name">{{item.name}}</view>
          <view class="bristol-type-num">第{{item.type}}型</view>
          <view class="bristol-check-icon" wx:if="{{selectedType === item.type}}">✓</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 类型建议 -->
  <view class="advice-card fade-in-1" wx:if="{{selectedType}}">
    <view class="advice-dot"></view>
    <view class="advice-text">{{advice}}</view>
  </view>

  <!-- 备注 -->
  <view class="card fade-in-2">
    <view class="section-title">📝 备注 <text class="optional">(选填)</text></view>
    <textarea
      class="note-input"
      placeholder="吃了什么？身体感受？"
      value="{{note}}"
      bindinput="onNoteInput"
      maxlength="200"
    />
    <view class="note-counter">{{note.length}}/200</view>
  </view>

  <!-- 位置 -->
  <view class="card fade-in-2">
    <view class="setting-row">
      <view class="setting-left">
        <view class="setting-icon">📍</view>
        <view class="setting-label">记录位置</view>
      </view>
      <switch checked="{{recordLocation}}" bindchange="toggleLocation" color="#6b8e4e" />
    </view>
    <view class="location-detail" wx:if="{{recordLocation && locationName}}">
      <view class="loc-dot pulse-dot"></view>
      {{locationName}}
    </view>
    <view class="location-detail dim" wx:if="{{recordLocation && !locationName}}">
      正在获取位置…
    </view>
  </view>

  <!-- 按钮 -->
  <view class="save-row fade-in-3">
    <button class="btn-skip" bindtap="skip">跳过</button>
    <button class="btn-save {{selectedType ? 'ready' : ''}}" bindtap="save" disabled="{{!selectedType}}">
      <text class="btn-save-text">{{selectedType ? '保存记录' : '请先选择类型'}}</text>
    </button>
  </view>
</view>
