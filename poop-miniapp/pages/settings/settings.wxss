/* ========== 设置行 ========== */
.setting-row {
  display:flex; justify-content:space-between; align-items:center;
  padding:18rpx 0;
}
.setting-row.divider { border-bottom:1rpx solid var(--border-light); }
.setting-label { font-size:28rpx; color:var(--text); }
.setting-val {
  display:flex; align-items:center; gap:6rpx;
  font-size:28rpx; color:var(--sub); font-weight:500;
}
.val-arrow { font-size:32rpx; color:var(--sub2); }

.danger-label { color:var(--accent2); font-weight:500; }
.danger-val { color:var(--accent2); }

/* ========== 导航行 ========== */
.nav-row {
  display:flex; align-items:center; gap:16rpx;
  padding:20rpx 0; transition:background 0.15s;
}
.nav-row.divider { border-bottom:1rpx solid var(--border-light); }
.row-hover { background:rgba(0,0,0,0.02); margin:0 -30rpx; padding-left:30rpx; padding-right:30rpx; }
.theme-dark .row-hover { background:rgba(255,255,255,0.02); }
.nav-icon { font-size:32rpx; width:44rpx; text-align:center; }
.nav-label { font-size:28rpx; color:var(--text); flex:1; }
.nav-arrow { font-size:32rpx; color:var(--sub2); }

.version-tag {
  background:var(--bg); padding:6rpx 18rpx; border-radius:var(--radius-sm);
  font-size:24rpx; color:var(--sub2); font-family:'SF Mono','Courier New',monospace;
}

/* ========== Footer ========== */
.settings-footer { text-align:center; padding:40rpx 0 60rpx; }
.footer-text { font-size:24rpx; color:var(--sub2); }
