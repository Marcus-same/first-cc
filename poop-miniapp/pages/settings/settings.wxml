<view class="container {{dark ? 'theme-dark' : ''}}">
  <!-- 久蹲提醒 -->
  <view class="card fade-in">
    <view class="section-title">⏰ 久蹲提醒</view>
    <view class="setting-row">
      <view class="setting-label">开启提醒</view>
      <switch checked="{{warnEnabled}}" bindchange="toggleWarn" color="#6b8e4e" />
    </view>
    <view class="setting-row divider" wx:if="{{warnEnabled}}">
      <view class="setting-label">提醒时长</view>
      <view class="setting-val" bindtap="showWarnPicker">
        {{warnMin}} 分钟
        <text class="val-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 暗黑模式 -->
  <view class="card fade-in-1">
    <view class="section-title">🌙 外观</view>
    <view class="setting-row">
      <view class="setting-label">主题模式</view>
      <picker class="picker" mode="selector" range="{{themeOptions}}" value="{{themeIdx}}" bindchange="changeTheme">
        <view class="setting-val">
          {{themeOptions[themeIdx]}}
          <text class="val-arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="card fade-in-1">
    <view class="section-title">💾 数据管理</view>
    <view class="setting-row divider" bindtap="exportData">
      <view class="setting-label">导出记录</view>
      <view class="setting-val">
        JSON
        <text class="val-arrow">›</text>
      </view>
    </view>
    <view class="setting-row danger-row" bindtap="clearData">
      <view class="setting-label danger-label">清除所有数据</view>
      <view class="setting-val danger-val">
        不可恢复
        <text class="val-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 更多功能 -->
  <view class="card fade-in-2">
    <view class="section-title">🎮 更多功能</view>
    <view class="nav-row divider" bindtap="goSquad" hover-class="row-hover">
      <view class="nav-icon">👥</view>
      <view class="nav-label">我的战队</view>
      <view class="nav-arrow">›</view>
    </view>
    <view class="nav-row divider" bindtap="goMap" hover-class="row-hover">
      <view class="nav-icon">🗺️</view>
      <view class="nav-label">拉屎地图</view>
      <view class="nav-arrow">›</view>
    </view>
    <view class="nav-row divider" bindtap="goPersonality" hover-class="row-hover">
      <view class="nav-icon">🧬</view>
      <view class="nav-label">肠道人格</view>
      <view class="nav-arrow">›</view>
    </view>
    <view class="nav-row" bindtap="goOnboarding" hover-class="row-hover">
      <view class="nav-icon">📖</view>
      <view class="nav-label">重新查看引导</view>
      <view class="nav-arrow">›</view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="card fade-in-2">
    <view class="section-title">ℹ️ 关于</view>
    <view class="nav-row divider" bindtap="goPrivacy" hover-class="row-hover">
      <view class="nav-label">隐私政策</view>
      <view class="nav-arrow">›</view>
    </view>
    <view class="nav-row divider" bindtap="goAgreement" hover-class="row-hover">
      <view class="nav-label">用户协议</view>
      <view class="nav-arrow">›</view>
    </view>
    <view class="nav-row divider" bindtap="sendFeedback" hover-class="row-hover">
      <view class="nav-label">反馈建议</view>
      <view class="nav-arrow">›</view>
    </view>
    <view class="nav-row">
      <view class="nav-label">版本</view>
      <view class="version-tag">v2.0.0</view>
    </view>
  </view>

  <!-- Footer -->
  <view class="settings-footer">
    <view class="footer-text">肠道日历 · 关心你的每一天</view>
  </view>
</view>
