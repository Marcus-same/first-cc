/* ========== 邀请码卡片 ========== */
.code-card {
  text-align:center; margin:16rpx 20rpx; padding:36rpx 30rpx;
  background:linear-gradient(135deg, #f8fbf5, #f0f5e8, #f5f8f0);
  border-radius:var(--radius-lg); box-shadow:var(--shadow-md);
}
.theme-dark .code-card {
  background:linear-gradient(135deg, #1e2418, #1a2016, #1e2218);
}
.code-label { font-size:26rpx; color:var(--sub); margin-bottom:20rpx; }
.code-row { display:flex; justify-content:center; gap:12rpx; margin-bottom:28rpx; }
.code-char {
  width:68rpx; height:80rpx; line-height:80rpx;
  background:var(--card); border-radius:var(--radius-sm);
  font-size:40rpx; font-weight:800; font-family:'SF Mono','Courier New',monospace;
  color:var(--accent); box-shadow:var(--shadow-sm);
}
.code-actions { display:flex; gap:16rpx; }
.btn-invite {
  flex:1; background:var(--accent); color:#fff; border-radius:var(--radius-full);
  padding:18rpx; font-size:26rpx; font-weight:600; border:none;
  box-shadow:0 4rpx 16rpx rgba(107,142,78,0.2);
}
.btn-invite:active { transform:scale(0.96); }
.btn-data {
  flex:1; background:transparent; color:var(--accent); border-radius:var(--radius-full);
  padding:18rpx; font-size:26rpx; font-weight:500; border:2rpx solid var(--accent);
}
.btn-data:active { background:rgba(107,142,78,0.05); }

/* ========== 添加好友 ========== */
.tappable { cursor:pointer; }
.count-badge {
  display:inline-flex; align-items:center; justify-content:center;
  min-width:36rpx; height:36rpx; border-radius:18rpx;
  background:var(--accent); color:#fff; font-size:22rpx; padding:0 8rpx;
  margin-left:8rpx;
}
.add-form { margin-top:20rpx; }
.input-wrap {
  display:flex; align-items:center; gap:12rpx;
  background:var(--bg); border:1rpx solid var(--border); border-radius:var(--radius-sm);
  padding:0 16rpx; margin-bottom:14rpx;
}
.input-prefix { font-size:28rpx; color:var(--sub2); }
.add-input { flex:1; height:80rpx; font-size:28rpx; color:var(--text); }
.btn-add-friend {
  width:100%; background:var(--accent2); color:#fff; border-radius:var(--radius-sm);
  padding:18rpx; font-size:28rpx; font-weight:600; border:none;
}
.btn-add-friend:active { opacity:0.85; }

/* ========== 好友列表 ========== */
.friend-item {
  display:flex; align-items:center; gap:16rpx; padding:18rpx 0;
  border-bottom:1rpx solid var(--border-light);
}
.friend-item:last-child { border-bottom:none; }
.friend-avatar {
  width:64rpx; height:64rpx; border-radius:50%;
  background:linear-gradient(135deg, var(--accent-light), var(--accent));
  color:#fff; font-size:28rpx; font-weight:700;
  display:flex; align-items:center; justify-content:center;
}
.friend-info { flex:1; }
.friend-name { font-size:28rpx; font-weight:600; color:var(--text); }
.friend-code { font-size:22rpx; color:var(--sub2); margin-top:2rpx; }
.friend-stats { font-size:24rpx; color:var(--accent); margin-top:4rpx; }
.friend-stats.dim { color:var(--sub2); font-style:italic; }
.friend-arrow { font-size:32rpx; color:var(--sub2); }

/* ========== 空好友 ========== */
.empty-friends { text-align:center; padding:60rpx 40rpx; }
.empty-icon { font-size:80rpx; margin-bottom:16rpx; }
.empty-text { font-size:30rpx; color:var(--text); margin-bottom:12rpx; }
.empty-sub { font-size:26rpx; color:var(--sub2); line-height:1.8; }

/* ========== 排行榜 ========== */
.lb-item {
  display:flex; align-items:center; gap:14rpx; padding:16rpx 0;
  border-bottom:1rpx solid var(--border-light);
}
.lb-item:last-child { border-bottom:none; }
.lb-item.is-me {
  background:rgba(107,142,78,0.04); border-radius:var(--radius-sm);
  padding:16rpx 12rpx; margin:0 -12rpx; border:none;
}
.lb-rank { font-size:28rpx; width:48rpx; text-align:center; }
.lb-rank.gold, .lb-rank.silver, .lb-rank.bronze { font-size:36rpx; }
.lb-avatar {
  width:48rpx; height:48rpx; border-radius:50%;
  background:var(--card2); display:flex; align-items:center; justify-content:center;
  font-size:24rpx; font-weight:600; color:var(--sub);
}
.lb-name { font-size:28rpx; font-weight:600; color:var(--text); flex:1; }
.lb-stats { display:flex; gap:6rpx; }
.lb-badge {
  font-size:22rpx; color:var(--sub); background:var(--card2);
  padding:4rpx 10rpx; border-radius:var(--radius-sm);
}

/* ========== PK 弹窗 ========== */
.pk-overlay {
  position:fixed; top:0; left:0; right:0; bottom:0;
  background:rgba(0,0,0,0.5); z-index:100;
  display:flex; align-items:center; justify-content:center;
}
.pk-modal {
  width:600rpx; background:var(--card); border-radius:var(--radius-lg);
  padding:36rpx 30rpx; box-shadow:var(--shadow-lg);
}
.pk-title { text-align:center; font-size:36rpx; font-weight:800; color:var(--text); margin-bottom:24rpx; }
.pk-vs-row { display:flex; align-items:center; justify-content:center; gap:28rpx; margin-bottom:20rpx; }
.pk-me, .pk-friend { text-align:center; }
.pk-avatar {
  width:72rpx; height:72rpx; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:32rpx; margin:0 auto 8rpx;
}
.pk-avatar.me { background:linear-gradient(135deg, #ffd54f, #ffa000); color:#fff; }
.pk-avatar.friend { background:linear-gradient(135deg, #81c784, #4caf50); color:#fff; }
.pk-name { font-size:28rpx; font-weight:600; color:var(--text); }
.pk-vs { font-size:32rpx; font-weight:800; color:var(--sub2); }
.pk-winner { text-align:center; font-size:30rpx; font-weight:700; color:var(--accent4); margin-bottom:20rpx; }
.pk-items { }
.pk-row {
  display:flex; align-items:center; gap:12rpx;
  padding:16rpx 12rpx; border-radius:var(--radius-sm);
}
.pk-row:nth-child(even) { background:var(--card2); }
.pk-val {
  font-size:24rpx; font-weight:600; color:var(--sub); min-width:70rpx; text-align:center;
}
.pk-val.win { color:var(--accent); font-weight:800; }
.pk-val.me { text-align:right; }
.pk-val.friend { text-align:left; }
.pk-icon { font-size:28rpx; width:48rpx; text-align:center; }
.pk-label { font-size:24rpx; color:var(--sub2); flex:1; text-align:center; }
.pk-close-btn {
  margin-top:24rpx; text-align:center; padding:16rpx;
  background:var(--card2); border-radius:var(--radius-full);
  font-size:28rpx; color:var(--sub);
}
