.container { position:relative; height:100vh; }
.map-view { width:100%; height:100%; }

/* ========== 筛选标签 ========== */
.filter-bar { position:absolute; top:20rpx; left:20rpx; right:20rpx; display:flex; gap:8rpx; z-index:10; }
.filter-tab { flex:1; text-align:center; background:rgba(255,255,255,0.92); border-radius:30rpx; padding:14rpx 4rpx; font-size:22rpx; color:#666; backdrop-filter:blur(10px); }
.filter-tab.active { background:var(--accent); color:#fff; font-weight:bold; }
.theme-dark .filter-tab { background:rgba(30,30,50,0.92); color:#aaa; }
.theme-dark .filter-tab.active { background:var(--accent); color:#fff; }

/* ========== 数据统计栏 ========== */
.stats-bar {
  position:absolute; bottom:115rpx; left:20rpx; right:20rpx;
  display:flex;
  background:rgba(255,255,255,0.95); border-radius:20rpx;
  padding:20rpx 14rpx; z-index:10;
  box-shadow:0 4rpx 20rpx rgba(0,0,0,0.10);
}
.theme-dark .stats-bar { background:rgba(30,30,50,0.95); }
.stat-item { flex:1; text-align:center; }
.stat-num { font-size:36rpx; font-weight:bold; color:var(--accent); }
.stat-label { font-size:22rpx; color:var(--sub); margin-top:4rpx; }

/* ========== 底部操作栏 ========== */
.map-bottom-bar {
  position:absolute; bottom:28rpx; left:20rpx; right:20rpx;
  display:flex; align-items:center;
  background:rgba(255,255,255,0.94); backdrop-filter:blur(14px);
  border-radius:50rpx;
  z-index:10;
  box-shadow:0 6rpx 24rpx rgba(74,124,89,0.12);
  border:1rpx solid rgba(74,124,89,0.10);
}
.theme-dark .map-bottom-bar {
  background:rgba(30,35,40,0.94);
  border-color:rgba(74,124,89,0.16);
}
.mba-item {
  flex:1; text-align:center; padding:18rpx 0;
  font-size:26rpx; font-weight:600; color:var(--text);
}
.mba-btn {
  background:transparent; border:none; margin:0; padding:18rpx 0;
  line-height:1.5; border-radius:50rpx;
}
.mba-btn::after { border:none; }  /* 去掉微信 button 默认边框 */
.mba-hover { background:rgba(74,124,89,0.06); }
.mba-divider {
  width:1rpx; height:28rpx; background:var(--border-light); flex-shrink:0;
}

/* ========== 空状态 ========== */
.empty-hint {
  position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
  text-align:center;
  background:rgba(255,255,255,0.95); border-radius:24rpx;
  padding:40rpx 36rpx; z-index:5;
  width:calc(100% - 80rpx); max-width:480rpx;
  box-shadow:0 8rpx 40rpx rgba(0,0,0,0.12);
}
.theme-dark .empty-hint { background:rgba(30,30,50,0.95); }
.hint-icon { font-size:90rpx; margin-bottom:16rpx; }
.hint-text { font-size:30rpx; color:var(--text); margin-bottom:10rpx; }
.hint-sub { font-size:24rpx; color:var(--sub); line-height:1.6; }
