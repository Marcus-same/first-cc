/* ========== 空状态 ========== */
.empty-state { text-align:center; padding:140rpx 40rpx 100rpx; }
.empty-illust { position:relative; margin-bottom:40rpx; }
.empty-glow {
  width:180rpx; height:180rpx; border-radius:50%;
  background: radial-gradient(circle, rgba(74,124,89,0.10) 0%, transparent 70%);
  position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
  animation: breathe 3s ease-in-out infinite;
}
.empty-emoji { font-size:120rpx; position:relative; z-index:1; }
.empty-title { font-size:36rpx; font-weight:700; color:var(--text); margin-bottom:14rpx; letter-spacing: -0.5rpx; }
.empty-sub { font-size:27rpx; color:var(--sub2); line-height:1.6; }

/* ========== 人格卡片 ========== */
.persona-wrap { padding:0 22rpx; }
.persona-card {
  position:relative; text-align:center; padding:56rpx 44rpx 48rpx;
  border-radius: var(--radius-xl); overflow:hidden;
  background: var(--card);
  box-shadow: var(--shadow-lg);
  border: 1rpx solid var(--border-light);
  animation: bounceInUp 0.55s var(--ease-spring);
  transition: all var(--duration-normal);
  margin-top: 16rpx;
}
.persona-card::before {
  content: '';
  position: absolute;
  top: -40%; right: -25%;
  width: 280rpx; height: 280rpx;
  background: radial-gradient(circle, rgba(74,124,89,0.06) 0%, transparent 65%);
  pointer-events: none;
}
.persona-card::after {
  content: '';
  position: absolute;
  bottom: -20%; left: -10%;
  width: 160rpx; height: 160rpx;
  background: radial-gradient(circle, rgba(200,134,58,0.04) 0%, transparent 65%);
  pointer-events: none;
}
.theme-dark .persona-card { border-color: var(--border); }
.persona-card.morning_elf {
  background: linear-gradient(160deg, #fff8e6, #fff3d6, #fffbe6);
  border-top: 3rpx solid #f5c542;
}
.persona-card.golden {
  background: linear-gradient(160deg, #f6fbf0, #eef7e0, #f4f9ec);
  border-top: 3rpx solid var(--accent);
}
.persona-card.speed {
  background: linear-gradient(160deg, #f4f8ff, #e8f0ff, #f0f4ff);
  border-top: 3rpx solid #6b8ae8;
}
.persona-card.thinker {
  background: linear-gradient(160deg, #f8f4ff, #f0e8ff, #f4f0ff);
  border-top: 3rpx solid #a78bfa;
}
.persona-card.rainbow {
  background: linear-gradient(160deg, #fff4f8, #ffe8f0, #fff0f4);
  border-top: 3rpx solid #f472b6;
}
.persona-card.explorer {
  background: linear-gradient(160deg, #f4fff8, #e8fff0, #f0fff4);
  border-top: 3rpx solid var(--accent-light);
}
.persona-card.night_owl {
  background: linear-gradient(160deg, #f4f4ff, #e8e6ff, #f0eeff);
  border-top: 3rpx solid #818cf8;
}
.persona-card.rhythm {
  background: linear-gradient(160deg, #e8f0ff, #dce6ff, #e6eeff);
  border-top: 3rpx solid #60a5fa;
}
.persona-card.iron_gut {
  background: linear-gradient(160deg, #fff0e8, #ffe6d6, #ffece0);
  border-top: 3rpx solid var(--accent2);
}
.persona-card.focused {
  background: linear-gradient(160deg, #f0f8e8, #e8f5dc, #ecf5e4);
  border-top: 3rpx solid var(--accent-dark);
}
.persona-card.afternoon {
  background: linear-gradient(160deg, #fff8f0, #fff5ea, #fff8f0);
  border-top: 3rpx solid #fbbf24;
}
.persona-card.balanced {
  background: linear-gradient(160deg, #f5f5f0, #eef0ea, #f2f2ee);
  border-top: 3rpx solid #a8a89a;
}

/* ========== 编码 ========== */
.poo-code {
  display:inline-flex; align-items:center; gap:10rpx;
  margin:0 auto 24rpx; padding:10rpx 28rpx;
  background: rgba(0,0,0,0.04);
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border-light);
  transition: all var(--duration-normal);
  animation: fadeInUp 0.4s var(--ease-out) 0.2s both;
}
.theme-dark .poo-code { background: rgba(255,255,255,0.05); }
.poo-label { font-size:22rpx; font-weight:600; color:var(--sub2); letter-spacing:2rpx; }
.poo-value {
  font-size:30rpx; font-weight:800; color:var(--accent);
  letter-spacing:3rpx;
  animation: breathe 2s ease-in-out infinite;
}

.persona-badge {
  display:inline-block; padding:8rpx 30rpx; border-radius: var(--radius-full);
  background: var(--card2); font-size:22rpx; color:var(--sub); margin-bottom:28rpx;
  animation: fadeInUp 0.4s var(--ease-out) 0.15s both;
  border: 1rpx solid var(--border);
  letter-spacing: 1rpx;
}
.theme-dark .persona-badge { background: rgba(255,255,255,0.05); }
.persona-icon {
  font-size:130rpx; margin-bottom:24rpx;
  animation: bounceIn 0.7s var(--ease-spring) 0.1s both;
  filter: drop-shadow(0 8rpx 16rpx rgba(0,0,0,0.10));
}
.persona-name {
  font-size:46rpx; font-weight:800; color:var(--text); margin-bottom:18rpx;
  animation: fadeInUp 0.4s var(--ease-out) 0.2s both;
  letter-spacing: -0.5rpx;
}
.persona-desc {
  font-size:28rpx; color:var(--sub); line-height:1.85;
  animation: fadeInUp 0.4s var(--ease-out) 0.3s both;
}

/* ========== 四维度分析 ========== */
.dims-wrap {
  display:flex; flex-direction:column; gap:24rpx;
}
.dim-row {
  display:flex; align-items:center; gap:16rpx;
  animation: fadeInUp 0.4s var(--ease-out) both;
}
.dim-row:nth-child(1) { animation-delay: 0.1s; }
.dim-row:nth-child(2) { animation-delay: 0.16s; }
.dim-row:nth-child(3) { animation-delay: 0.22s; }
.dim-row:nth-child(4) { animation-delay: 0.28s; }
.dim-header { width:84rpx; display:flex; flex-direction:column; align-items:center; gap:4rpx; }
.dim-name { font-size:24rpx; color:var(--text); font-weight:500; }
.dim-code { font-size:20rpx; color:var(--accent); font-weight:700; }
.dim-bar-wrap {
  flex:1; height:18rpx;
  background: var(--border-light);
  border-radius:9rpx; overflow:hidden;
}
.dim-bar {
  height:100%; border-radius:9rpx;
  animation: progressFill 1s var(--ease-out);
  min-width:4rpx;
}
.dim-bar-time { background: linear-gradient(90deg, #ffb347, #ff8c00); }
.dim-bar-speed { background: linear-gradient(90deg, #4ecdc4, #2d9e92); }
.dim-bar-type { background: linear-gradient(90deg, #a78bfa, #7c3aed); }
.dim-bar-rhythm { background: linear-gradient(90deg, #f97373, #dc4545); }
.dim-label { width:64rpx; font-size:22rpx; color:var(--sub2); text-align:right; }

/* ========== 核心优势 + 建议 ========== */
.strength-body { font-size:28rpx; color:var(--sub); line-height:1.9; }
.advice-card {
  margin:0 0 20rpx; padding:28rpx 32rpx;
  background: var(--card); border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm); border: 1rpx solid var(--border-light);
  border-left: 5rpx solid var(--accent3);
  animation: fadeInUp 0.4s var(--ease-out) 0.1s both;
  transition: all var(--duration-normal);
  position: relative;
  overflow: hidden;
}
.advice-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, var(--border-mid) 50%, transparent 100%);
}
.advice-card:active { transform: scale(0.99); }
.advice-title { font-size:30rpx; font-weight:600; margin-bottom:16rpx; color:var(--text); }
.advice-body { font-size:28rpx; color:var(--sub); line-height:1.85; }

/* ========== 自测入口 ========== */
.test-entry {
  display:flex; align-items:center; gap:18rpx;
  margin:22rpx 22rpx; padding:28rpx 32rpx;
  background: var(--card); border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 1.5rpx solid var(--border-light);
  transition: all var(--duration-normal) var(--ease-spring);
  animation: fadeInUp 0.4s var(--ease-out) 0.2s both;
}
.test-entry-top {
  background: linear-gradient(135deg, rgba(74,124,89,0.06), rgba(74,124,89,0.02));
  border: 2rpx solid var(--accent);
  border-left: 6rpx solid var(--accent);
  margin:16rpx 22rpx 0;
}
.test-badge {
  background: linear-gradient(135deg, var(--accent), var(--accent-dark));
  color:#fff; font-size:22rpx; font-weight:700;
  padding:4rpx 16rpx; border-radius:var(--radius-full);
  flex-shrink:0;
}
.test-entry:active {
  transform: scale(0.97);
  border-color: var(--accent);
  box-shadow: var(--shadow-glow);
}
.test-icon { font-size:52rpx; flex-shrink: 0; }
.test-info { flex:1; }
.test-title { font-size:30rpx; font-weight:700; color:var(--text); margin-bottom:6rpx; }
.test-desc { font-size:24rpx; color:var(--sub2); }
.test-arrow {
  font-size:34rpx; color:var(--sub2);
  transition: transform var(--duration-fast);
}
.test-entry:active .test-arrow { transform: translateX(8rpx); }

/* ========== 数据来源 ========== */
.source-card {
  margin:22rpx 0; text-align:center;
  padding:20rpx; background:var(--card); border-radius:var(--radius-md);
  font-size:26rpx; color:var(--sub2); box-shadow: var(--shadow-sm);
  display:flex; align-items:center; justify-content:center; gap:10rpx;
  animation: fadeInUp 0.4s var(--ease-out) 0.15s both;
  border: 1rpx solid var(--border-light);
}
.source-dot {
  width:8rpx; height:8rpx; border-radius:50%;
  background: var(--accent);
  animation: breathe 2s ease-in-out infinite;
}
.source-num { color:var(--accent); font-weight:700; }

/* ========== 分享 ========== */
.share-wrap { margin-top:18rpx; animation: fadeInUp 0.4s var(--ease-out) 0.25s both; }
.btn-share-persona {
  width:100%;
  background: linear-gradient(135deg, var(--accent), var(--accent-dark));
  color:#fff; border-radius: var(--radius-full);
  padding:26rpx; font-size:30rpx; font-weight:600; border:none;
  box-shadow: 0 6rpx 24rpx rgba(74,124,89,0.28);
  transition: all var(--duration-fast) var(--ease-spring);
  letter-spacing: 1rpx;
}
.btn-share-persona:active {
  transform: scale(0.97);
  box-shadow: 0 3rpx 12rpx rgba(74,124,89,0.20);
}