.container { min-height:100vh; padding-bottom:40rpx; }
.empty { text-align:center; padding:120rpx 40rpx; }
.empty-icon { font-size:120rpx; margin-bottom:24rpx; }
.empty-text { font-size:36rpx; color:var(--text); margin-bottom:12rpx; }
.empty-sub { font-size:28rpx; color:var(--sub); }
.persona-card { text-align:center; padding:60rpx 40rpx; }
.persona-icon { font-size:140rpx; margin-bottom:24rpx; }
.persona-name { font-size:44rpx; font-weight:bold; color:var(--text); margin-bottom:20rpx; }
.persona-desc { font-size:30rpx; color:var(--sub); line-height:1.8; }
.personality-detail { }
.detail-title { font-size:30rpx; font-weight:bold; margin-bottom:20rpx; }
.detail-item { font-size:28rpx; color:var(--sub); line-height:1.8; margin-bottom:16rpx; }
.stats-mini { text-align:center; }
.stats-text { font-size:26rpx; color:var(--sub); }
.highlight { color:var(--accent); font-weight:bold; }
.share-row { padding:20rpx; }
.btn-share { width:100%; background:var(--accent); color:#fff; border-radius:50rpx; padding:24rpx; font-size:30rpx; border:none; }