<view class="container {{dark ? 'theme-dark' : ''}}">
  <!-- 无数据 -->
  <view wx:if="{{!persona}}" class="empty-state fade-in">
    <view class="empty-illust">
      <view class="empty-glow"></view>
      <view class="empty-emoji">🌱</view>
    </view>
    <view class="empty-title">还没有足够数据</view>
    <view class="empty-sub">记录几天后再来看看你的肠道人格</view>
  </view>

  <!-- 人格卡片 -->
  <view wx:if="{{persona}}" class="persona-wrap fade-in">
    <view class="persona-card {{persona.id}}">
      <view class="persona-badge">你的肠道人格</view>
      <view class="persona-icon">{{persona.icon}}</view>
      <view class="persona-name">{{persona.name}}</view>
      <!-- BPTI 编码 -->
      <view class="poo-code" wx:if="{{code !== '--'}}">
        <text class="poo-label">BPTI</text>
        <text class="poo-value">{{code}}</text>
      </view>
      <view class="persona-desc">{{persona.desc}}</view>
    </view>

    <!-- 四维度分析 -->
    <view class="card fade-in-1" wx:if="{{dims}}">
      <view class="section-title">📊 四维度分析</view>
      <view class="dims-wrap">
        <view class="dim-row">
          <view class="dim-header">
            <text class="dim-name">时段</text>
            <text class="dim-code">{{code.split('-')[0] || '-'}}</text>
          </view>
          <view class="dim-bar-wrap">
            <view class="dim-bar dim-bar-time" style="width:{{dims.time}}%"></view>
          </view>
          <view class="dim-label">{{dims.time < 35 ? '晨型' : dims.time > 65 ? '夜型' : '均衡'}}</view>
        </view>
        <view class="dim-row">
          <view class="dim-header">
            <text class="dim-name">速度</text>
            <text class="dim-code">{{code.split('-')[1] || '-'}}</text>
          </view>
          <view class="dim-bar-wrap">
            <view class="dim-bar dim-bar-speed" style="width:{{dims.speed}}%"></view>
          </view>
          <view class="dim-label">{{dims.speed < 30 ? '快速' : dims.speed > 65 ? '慢速' : '适中'}}</view>
        </view>
        <view class="dim-row">
          <view class="dim-header">
            <text class="dim-name">类型</text>
            <text class="dim-code">{{code.split('-')[2] || '-'}}</text>
          </view>
          <view class="dim-bar-wrap">
            <view class="dim-bar dim-bar-type" style="width:{{dims.type}}%"></view>
          </view>
          <view class="dim-label">{{dims.type < 30 ? '专一' : dims.type > 65 ? '多样' : '均衡'}}</view>
        </view>
        <view class="dim-row">
          <view class="dim-header">
            <text class="dim-name">节律</text>
            <text class="dim-code">{{code.split('-')[3] || '-'}}</text>
          </view>
          <view class="dim-bar-wrap">
            <view class="dim-bar dim-bar-rhythm" style="width:{{dims.rhythm}}%"></view>
          </view>
          <view class="dim-label">{{dims.rhythm < 35 ? '规律' : '随性'}}</view>
        </view>
      </view>
    </view>

    <!-- 核心优势 -->
    <view class="card fade-in-1" wx:if="{{persona.strength}}">
      <view class="section-title">💪 核心优势</view>
      <view class="strength-body">{{persona.strength}}</view>
    </view>

    <!-- 行动建议 -->
    <view class="advice-card fade-in-2" wx:if="{{persona.advice}}">
      <view class="advice-title">💡 行动建议</view>
      <view class="advice-body">{{persona.advice}}</view>
    </view>

    <!-- 数据来源 -->
    <view class="source-card fade-in-2" wx:if="{{persona}}">
      <view class="source-dot"></view>
      基于 <text class="source-num">{{totalSessions}}</text> 次记录分析得出
    </view>

    <!-- 分享 -->
    <view class="share-wrap fade-in-3" wx:if="{{persona}}">
      <button class="btn-share-persona" open-type="share">
        📤 分享我的肠道人格（{{code}}）
      </button>
    </view>
  </view>

  <!-- 自测入口（始终可见） -->
  <view class="test-entry fade-in-3" bindtap="goTest">
    <view class="test-icon">📝</view>
    <view class="test-info">
      <view class="test-title">BPTI 自测</view>
      <view class="test-desc">回答 12 道题，看看你的肠道人格类型</view>
    </view>
    <view class="test-arrow">→</view>
  </view>
</view>
