.container { min-height:100vh; display:flex; flex-direction:column; }
.swiper { flex:1; }
.slide { display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; padding:60rpx; }
.slide-emoji { font-size:160rpx; margin-bottom:40rpx; }
.slide-title { font-size:44rpx; font-weight:bold; color:var(--text); margin-bottom:24rpx; }
.slide-desc { font-size:30rpx; color:var(--sub); text-align:center; line-height:1.8; white-space:pre-line; }
.onboarding-footer { padding:40rpx 60rpx 60rpx; text-align:center; }
.dots { display:flex; justify-content:center; gap:12rpx; margin-bottom:30rpx; }
.dot { width:12rpx; height:12rpx; border-radius:50%; transition:.3s; }
.dot.active { width:30rpx; border-radius:6rpx; }
.btn-start { width:100%; color:#fff; border-radius:50rpx; padding:24rpx; font-size:34rpx; border:none; margin-bottom:16rpx; }
.btn-skip { font-size:28rpx; color:var(--sub); padding:12rpx; }
