.container { min-height:100vh; display:flex; flex-direction:column; background:var(--bg); }
.swiper { flex:1; }

.slide {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  height:100%; padding:30rpx 40rpx;
}
.slide-illust { position:relative; margin-bottom:28rpx; }
.slide-glow {
  width:160rpx; height:160rpx; border-radius:50%; opacity:0.10;
  position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
  background:radial-gradient(circle, var(--accent) 0%, transparent 70%);
}
.slide-emoji { font-size:110rpx; position:relative; z-index:1; }

.slide-title { font-size:36rpx; font-weight:800; color:var(--text); margin-bottom:12rpx; text-align:center; }
.slide-desc { font-size:26rpx; color:var(--sub); text-align:center; line-height:1.8; white-space:pre-line; word-break:break-word; overflow-wrap:break-word; overflow:hidden; }

.onboarding-footer { padding:30rpx 50rpx 60rpx; text-align:center; }
.progress-bar {
  height:6rpx; background:var(--border-light); border-radius:3rpx;
  margin-bottom:36rpx; overflow:hidden;
}
.progress-fill { height:100%; background:linear-gradient(90deg, var(--accent), var(--accent-light)); border-radius:3rpx; transition:width 0.3s ease-out; }
.btn-start {
  width:100%; color:#fff; border-radius:var(--radius-full);
  padding:26rpx; font-size:32rpx; font-weight:600; border:none;
  background:linear-gradient(135deg, var(--accent), var(--accent-dark));
  box-shadow:0 8rpx 30rpx rgba(126,200,80,0.30);
  transition:all 0.3s;
}
.btn-start:active { opacity:0.9; transform:scale(0.96); }
.swipe-hint { font-size:24rpx; color:var(--sub2); margin-top:20rpx; }
