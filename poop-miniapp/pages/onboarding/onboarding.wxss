.container { min-height:100vh; display:flex; flex-direction:column; background:var(--bg); }
.swiper { flex:1; }

.slide {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  height:100%; padding:60rpx 50rpx;
}
.slide-illust { position:relative; margin-bottom:48rpx; }
.slide-glow {
  width:200rpx; height:200rpx; border-radius:50%; opacity:0.08;
  position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
}
.slide-emoji { font-size:140rpx; position:relative; z-index:1; }

.slide-title { font-size:42rpx; font-weight:800; color:var(--text); margin-bottom:20rpx; text-align:center; }
.slide-desc { font-size:30rpx; color:var(--sub); text-align:center; line-height:1.9; white-space:pre-line; }

.onboarding-footer { padding:30rpx 50rpx 60rpx; text-align:center; }
.progress-bar {
  height:4rpx; background:var(--border-light); border-radius:2rpx;
  margin-bottom:36rpx; overflow:hidden;
}
.progress-fill { height:100%; border-radius:2rpx; transition:width 0.3s ease-out; }
.btn-start {
  width:100%; color:#fff; border-radius:var(--radius-full);
  padding:26rpx; font-size:32rpx; font-weight:600; border:none;
  box-shadow:0 8rpx 30rpx rgba(0,0,0,0.1);
  transition:background 0.3s;
}
.btn-start:active { opacity:0.9; transform:scale(0.98); }
.swipe-hint { font-size:24rpx; color:var(--sub2); margin-top:20rpx; }
