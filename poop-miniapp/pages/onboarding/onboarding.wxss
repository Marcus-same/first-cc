.container { min-height:100vh; display:flex; flex-direction:column; background:var(--bg); }
.swiper { flex:1; overflow:hidden; }

.slide {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  height:100%; padding:20rpx 40rpx 20rpx;
  box-sizing:border-box;
}
.slide-illust { position:relative; margin-bottom:16rpx; flex-shrink:0; }
.slide-glow {
  width:120rpx; height:120rpx; border-radius:50%;
  opacity:0.15;
  position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
  background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
  animation: breathe 3s ease-in-out infinite;
}
.slide-emoji {
  font-size:84rpx; position:relative; z-index:1;
  animation: bounceInUp 0.6s var(--ease-spring);
}

.slide-title {
  font-size:34rpx; font-weight:800; color:var(--text); margin-bottom:10rpx; text-align:center;
  animation: fadeInUp 0.4s var(--ease-out) 0.1s both;
  flex-shrink:0;
}
.slide-desc {
  font-size:26rpx; color:var(--sub); text-align:center;
  line-height:1.7; white-space:pre-line;
  word-break:break-word; overflow-wrap:break-word;
  padding:0 10rpx;
  animation: fadeInUp 0.4s var(--ease-out) 0.2s both;
}

.onboarding-footer { padding:16rpx 50rpx 40rpx; text-align:center; flex-shrink:0; }
.progress-bar {
  height:6rpx; background:var(--border-light); border-radius:3rpx;
  margin-bottom:36rpx; overflow:hidden;
}
.progress-fill {
  height:100%;
  background: linear-gradient(90deg, var(--accent), var(--accent-light));
  border-radius:3rpx;
  transition: width 0.4s var(--ease-out);
  animation: shimmer 1.5s ease-in-out infinite;
  background-size: 200% 100%;
}
.btn-start {
  width:100%; color:#fff; border-radius: var(--radius-full);
  padding:26rpx; font-size:32rpx; font-weight:600; border:none;
  background: linear-gradient(135deg, var(--accent), var(--accent-dark));
  box-shadow: 0 8rpx 30rpx rgba(74,124,89,0.28);
  transition: all var(--duration-normal) var(--ease-spring);
}
.btn-start:active { transform: scale(0.96); opacity: 0.9; box-shadow: 0 4rpx 15rpx rgba(74,124,89,0.18); }
.swipe-hint { font-size:24rpx; color:var(--sub2); margin-top:20rpx; }
