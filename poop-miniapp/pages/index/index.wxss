.container { min-height:100vh; padding-bottom:40rpx; }
.timer-card { text-align:center; padding:50rpx 30rpx; }
.emoji { font-size:140rpx; transition:.3s; }
.emoji.bounce { animation:bounce 0.6s infinite alternate; }
@keyframes bounce { from{transform:translateY(0)} to{transform:translateY(-18rpx)} }
.timer-text { font-size:88rpx; font-weight:bold; margin:30rpx 0; font-family:'Courier New',monospace; color:var(--accent); }
.btn-row { display:flex; justify-content:center; gap:24rpx; margin:20rpx 0; }
.btn-start { background:var(--accent); color:#fff; border-radius:40rpx; padding:20rpx 50rpx; font-size:32rpx; border:none; }
.btn-stop { background:var(--accent2); color:#fff; border-radius:40rpx; padding:20rpx 50rpx; font-size:32rpx; border:none; }
.tip { font-size:26rpx; color:var(--sub); margin-top:12rpx; }
.tip.warn { color:#e07b5a; font-weight:bold; }
.stats-row { display:flex; justify-content:space-around; text-align:center; padding:30rpx 20rpx; }
.stat-num { font-size:52rpx; font-weight:bold; color:var(--accent); }
.stat-label { font-size:24rpx; color:var(--sub); margin-top:6rpx; }
.daily-tip { display:flex; align-items:center; gap:20rpx; }
.tip-icon { font-size:44rpx; }
.tip-text { font-size:28rpx; color:var(--sub); line-height:1.6; flex:1; }
.quick-actions { display:flex; flex-wrap:wrap; gap:16rpx; padding:0 20rpx; margin-top:20rpx; }
.quick-btn { flex:1; min-width:200rpx; text-align:center; background:var(--card); border-radius:16rpx; padding:24rpx 16rpx; font-size:28rpx; color:var(--text); box-shadow:0 2rpx 12rpx rgba(0,0,0,0.05); }

.empty-state { display:flex; flex-direction:column; align-items:center; padding:80rpx 40rpx 40rpx; }
.empty-emoji { font-size:120rpx; margin-bottom:24rpx; }
.empty-title { font-size:36rpx; font-weight:bold; color:var(--text); margin-bottom:12rpx; }
.empty-sub { font-size:28rpx; color:var(--sub); }

.streak-card { padding:24rpx 30rpx; background:linear-gradient(135deg, #fff5e6, #ffe0b2); }
.theme-dark .streak-card { background:linear-gradient(135deg, #2a2a3e, #3a3020); }
.streak-inner { display:flex; align-items:center; gap:20rpx; }
.streak-emoji { font-size:56rpx; }
.streak-num { font-size:30rpx; color:#333; }
.theme-dark .streak-num { color:#eee; }
.streak-count { font-size:40rpx; font-weight:bold; color:#e07b5a; }
.streak-sub { font-size:24rpx; color:var(--sub); margin-top:4rpx; }

.fortune-card { text-align:center; padding:24rpx 30rpx; background:linear-gradient(135deg, #f0f4ff, #e8eaf6); }
.theme-dark .fortune-card { background:linear-gradient(135deg, #252545, #2a2a40); }
.fortune-stars { font-size:40rpx; }
.fortune-text { font-size:28rpx; color:var(--sub); margin-top:8rpx; }
