/* ========== 全局容器 ========== */
.container { padding:16rpx 0 60rpx; }

/* ========== 空状态 ========== */
.empty-state { display:flex; flex-direction:column; align-items:center; padding:60rpx 40rpx 40rpx; }
.empty-state-today { display:flex; flex-direction:column; align-items:center; padding:40rpx 40rpx 30rpx; }
.empty-illustration { margin-bottom:36rpx; }
.empty-state-today .empty-illustration { margin-bottom:20rpx; }
.empty-circle {
  width:200rpx; height:200rpx; border-radius:50%;
  background: linear-gradient(145deg, #f5ede0 0%, #ede4d4 60%, #e4d8c4 100%);
  box-shadow: var(--shadow-lg), 0 0 0 10rpx rgba(200,134,58,0.06);
  display:flex; align-items:center; justify-content:center; font-size:110rpx;
  border:3rpx solid rgba(200,134,58,0.10);
  animation: breathe 3.5s ease-in-out infinite;
  position: relative;
}
.empty-circle.relaxed {
  width:200rpx; height:200rpx; font-size:100rpx;
  background: linear-gradient(145deg, #e8f0e0 0%, #dce8d0 60%, #cde0c0 100%);
  box-shadow: var(--shadow-md), 0 0 0 8rpx rgba(74,124,89,0.04);
  border:3rpx solid rgba(74,124,89,0.08);
  animation: breathe 4s ease-in-out infinite;
}
.empty-circle::before {
  content: '';
  position: absolute;
  inset: -20rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(200,134,58,0.04) 0%, transparent 70%);
  animation: breathe 3.5s ease-in-out infinite 0.5s;
}
.empty-title { font-size:42rpx; font-weight:700; color:var(--text); margin-bottom:16rpx; letter-spacing: -0.5rpx; }
.empty-sub { font-size:28rpx; color:var(--sub); margin-bottom:36rpx; line-height:1.7; }
.empty-hint { font-size:26rpx; color:var(--sub2); background:var(--card2); border-radius:var(--radius-full); padding:18rpx 44rpx; border: 1rpx solid var(--border); }

/* ========== 计时卡片 ========== */
.timer-card {
  background: var(--card);
  border-radius:var(--radius-xl); padding:56rpx 40rpx 44rpx;
  margin:20rpx 22rpx; text-align:center;
  box-shadow: var(--shadow-md);
  transition: all var(--duration-slow) var(--ease-out);
  border: 1rpx solid var(--border-light);
  position: relative;
  overflow: hidden;
}
.timer-card::before {
  content: '';
  position: absolute;
  top: -60%; left: -60%;
  width: 220%; height: 220%;
  background: radial-gradient(circle at 35% 35%, rgba(74,124,89,0.05) 0%, transparent 55%);
  pointer-events: none;
}
.timer-card::after {
  content: '';
  position: absolute;
  bottom: -20%; right: -10%;
  width: 200rpx; height: 200rpx;
  background: radial-gradient(circle, rgba(200,134,58,0.05) 0%, transparent 70%);
  pointer-events: none;
}
.theme-dark .timer-card { border-color: var(--border); }
.timer-card.running {
  background: var(--card);
  border-color: var(--accent2);
  box-shadow: var(--shadow-lg), var(--shadow-glow2);
}

/* 环形进度 */
.timer-ring {
  width:220rpx; height:220rpx; border-radius:50%;
  margin:0 auto 36rpx;
  background: var(--card2);
  box-shadow: var(--shadow-md), inset 0 2rpx 8rpx rgba(0,0,0,0.04);
  display:flex; align-items:center; justify-content:center;
  transition: all var(--duration-slow) var(--ease-spring);
  border: 5rpx solid var(--border-light);
  position: relative;
  overflow: visible;
}
.timer-ring::before {
  content: '';
  position: absolute;
  top: -5rpx; left: -5rpx; right: -5rpx; bottom: -5rpx;
  border-radius: 50%;
  border: 5rpx solid transparent;
  border-top-color: var(--accent2);
  border-right-color: rgba(200,134,58,0.3);
  transform: rotate(0deg);
  transition: border-color 0.3s;
}
.timer-ring.pulse {
  border-color: var(--accent2);
  box-shadow: var(--shadow-glow2), 0 0 0 16rpx rgba(200,134,58,0.06);
  animation: ringPulse 2.5s ease-in-out infinite;
}
.timer-ring.pulse::before {
  animation: ringSpin 4s linear infinite;
  border-top-color: var(--accent2);
  border-right-color: rgba(200,134,58,0.5);
}
@keyframes ringSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
@keyframes ringPulse {
  0%, 100% { box-shadow: var(--shadow-glow2), 0 0 0 16rpx rgba(200,134,58,0.06); }
  50% { box-shadow: var(--shadow-glow2), 0 0 0 32rpx rgba(200,134,58,0.02); }
}
.timer-emoji { font-size:100rpx; transition: transform var(--duration-normal) var(--ease-spring); }
.timer-ring.pulse .timer-emoji { animation: emojiBounce 0.8s ease-in-out infinite alternate; }
@keyframes emojiBounce {
  from { transform: translateY(0) scale(1); }
  to { transform: translateY(-16rpx) scale(1.10); }
}

/* 时间文字 */
.timer-text {
  font-size:108rpx; font-weight:800; letter-spacing:4rpx;
  font-family: var(--font-mono);
  color:var(--text); margin-bottom:10rpx; transition: color var(--duration-normal);
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.06);
}
.timer-text.counting {
  color: var(--accent2);
  animation: timerPulse 1.2s ease-in-out infinite alternate;
}
@keyframes timerPulse {
  0% { opacity: 1; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.06); }
  100% { opacity: 0.82; text-shadow: 0 2rpx 12rpx rgba(200,134,58,0.25); }
}

.timer-label { font-size:26rpx; color:var(--sub2); margin-bottom:32rpx; letter-spacing: 0.5rpx; }
.timer-label.running-label { color:var(--accent2); font-weight:600; }

.btn-row { display:flex; justify-content:center; gap:20rpx; position: relative; z-index: 1; }
.btn-start, .btn-stop {
  display:flex; align-items:center; gap:10rpx;
  border-radius:var(--radius-full); padding:24rpx 52rpx;
  font-size:32rpx; font-weight:600; border:none;
  transition: all var(--duration-fast) var(--ease-spring);
  letter-spacing: 1rpx;
}
.btn-start {
  background: linear-gradient(135deg, var(--accent), var(--accent-dark));
  color:#fff;
  box-shadow: 0 6rpx 24rpx rgba(74,124,89,0.28);
}
.btn-start:active { transform:scale(0.95); box-shadow: 0 3rpx 12rpx rgba(74,124,89,0.20); }
.btn-stop {
  background: linear-gradient(135deg, var(--accent2), #b07030);
  color:#fff;
  box-shadow: 0 6rpx 24rpx rgba(200,134,58,0.28);
}
.btn-stop:active { transform:scale(0.95); box-shadow: 0 3rpx 12rpx rgba(200,134,58,0.20); }
.btn-icon { font-size:24rpx; }

.warn-banner {
  margin-top:24rpx; padding:16rpx 28rpx;
  background:rgba(200,134,58,0.08); border-radius:var(--radius-md);
  font-size:26rpx; color:var(--accent2); font-weight:600;
  border: 1rpx solid rgba(200,134,58,0.15);
  animation: shake 0.5s ease-out;
}

/* ========== 连续打卡 ========== */
.streak-card {
  background: linear-gradient(135deg, var(--card) 0%, var(--card2) 100%);
  border-radius:var(--radius-lg); padding:32rpx 34rpx;
  margin:20rpx 22rpx; display:flex; align-items:center; gap:28rpx;
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--border-light);
  border-left: 4rpx solid var(--accent4);
  animation: bounceInUp 0.55s var(--ease-spring);
  position: relative;
  overflow: hidden;
}
.streak-card::before {
  content: '';
  position: absolute;
  top: -40%; right: -5%;
  width: 160rpx; height: 160rpx;
  background: radial-gradient(circle, rgba(212,168,74,0.08) 0%, transparent 70%);
  pointer-events: none;
}
.theme-dark .streak-card {
  background: linear-gradient(135deg, var(--card) 0%, var(--card2) 100%);
  border-color: var(--border);
}
.streak-flame {
  font-size:72rpx;
  filter: drop-shadow(0 4rpx 16rpx rgba(255,160,0,0.30));
  animation: flameDance 1.8s ease-in-out infinite alternate;
  flex-shrink: 0;
}
@keyframes flameDance {
  0% { transform: translateY(0) scale(1) rotate(-2deg); }
  50% { transform: translateY(-6rpx) scale(1.08) rotate(1deg); }
  100% { transform: translateY(-3rpx) scale(1.04) rotate(-1deg); }
}
.streak-info { flex:1; }
.streak-num { font-size:28rpx; color:var(--text-soft); font-weight:500; }
.streak-count { font-size:56rpx; font-weight:800; color:var(--accent2); margin:0 6rpx; line-height:1.1; }
.streak-bar-wrap { height:8rpx; background:var(--border-light); border-radius:4rpx; margin:14rpx 0 10rpx; overflow:hidden; }
.streak-bar {
  height:100%;
  background: linear-gradient(90deg, var(--accent4), var(--accent2));
  border-radius:4rpx;
  transition: width 1s var(--ease-out);
  min-width:6rpx;
  animation: progressFill 1s var(--ease-out);
}
.streak-sub { font-size:24rpx; color:var(--sub); }

/* ========== 统计数字 ========== */
.stats-row { display:flex; gap:14rpx; padding:8rpx 22rpx 0; flex-wrap:wrap; }
.stats-row .stat-card { min-width:calc(25% - 10.5rpx); flex:1; }
.stat-card {
  flex:1; background:var(--card); border-radius:var(--radius-lg);
  padding:28rpx 12rpx 24rpx; text-align:center;
  box-shadow: var(--shadow-sm);
  transition: all var(--duration-normal) var(--ease-spring);
  border: 1rpx solid var(--border-light);
}
.stat-card:hover { transform: translateY(-3rpx); box-shadow: var(--shadow-md); }
.stat-card:active { transform: scale(0.97); }
.stat-icon { font-size:38rpx; margin-bottom:10rpx; }
.stat-num {
  font-size:46rpx; font-weight:800; color:var(--accent); line-height:1.2;
  transition: all var(--duration-normal);
  font-family: var(--font-mono);
}
.stat-label { font-size:22rpx; color:var(--sub2); margin-top:6rpx; }

/* ========== 每日运势 ========== */
.fortune-card {
  background: linear-gradient(135deg, var(--card) 0%, var(--card2) 100%);
  border-radius:var(--radius-lg); margin:20rpx 22rpx;
  box-shadow: var(--shadow-sm); overflow:hidden;
  border: 1rpx solid var(--border-light);
  border-top: 3rpx solid var(--accent3);
  animation: bounceInUp 0.55s var(--ease-spring) 0.1s both;
  position: relative;
  overflow: hidden;
}
.fortune-card::before {
  content: '';
  position: absolute;
  top: -50%; right: -30%;
  width: 200rpx; height: 200rpx;
  background: radial-gradient(circle, rgba(91,154,160,0.06) 0%, transparent 70%);
  pointer-events: none;
}
.theme-dark .fortune-card { border-color: var(--border); }
.fortune-inner { padding:32rpx 34rpx; text-align:center; }
.fortune-star-row { display:flex; justify-content:center; gap:10rpx; margin-bottom:16rpx; }
.fortune-star { font-size:44rpx; opacity:0.22; transition: opacity 0.4s, transform 0.4s; }
.fortune-star.lit {
  opacity:1;
  animation: starGlow 1.8s ease-in-out infinite alternate;
  filter: drop-shadow(0 0 8rpx rgba(245,197,66,0.5));
}
@keyframes starGlow {
  0% { transform: scale(1); }
  100% { transform: scale(1.20); }
}
.fortune-text { font-size:28rpx; color:var(--sub); line-height:1.7; }

/* ========== 每日挑战 ========== */
.challenge-card {
  margin:20rpx 22rpx; padding:28rpx 32rpx;
  background: var(--card); border-radius:var(--radius-lg); box-shadow: var(--shadow-sm);
  border-left: 5rpx solid var(--accent4);
  border-top: 1rpx solid var(--border-light);
  border-right: 1rpx solid var(--border-light);
  border-bottom: 1rpx solid var(--border-light);
  animation: bounceInUp 0.55s var(--ease-spring) 0.15s both;
  transition: all var(--duration-normal);
  position: relative;
  overflow: hidden;
}
.challenge-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, var(--border-mid) 50%, transparent 100%);
}
.challenge-card.done {
  opacity: 0.80;
  border-left-color: var(--accent);
}
.challenge-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:18rpx; }
.challenge-badge { font-size:26rpx; color:var(--accent4); font-weight:700; letter-spacing: 0.5rpx; }
.challenge-status { font-size:22rpx; color:var(--sub2); background:var(--card2); padding:6rpx 18rpx; border-radius:var(--radius-full); border: 1rpx solid var(--border); }
.challenge-status.done { color:var(--accent); background:rgba(74,124,89,0.08); border-color: rgba(74,124,89,0.15); }
.challenge-body { display:flex; align-items:center; gap:18rpx; }
.challenge-body.done { opacity:0.6; }
.challenge-icon { font-size:52rpx; }
.challenge-text { font-size:28rpx; color:var(--text); font-weight:600; }

/* ========== 每日小贴士 ========== */
.tip-card {
  display:flex; align-items:flex-start; gap:22rpx;
  background:var(--card); border-radius:var(--radius-lg);
  padding:28rpx 30rpx; margin:20rpx 22rpx;
  box-shadow: var(--shadow-sm); border: 1rpx solid var(--border-light);
  border-left: 5rpx solid var(--accent3);
  border-top: 1rpx solid var(--border-light);
  border-right: 1rpx solid var(--border-light);
  border-bottom: 1rpx solid var(--border-light);
  animation: fadeInUp var(--duration-slow) var(--ease-out) 0.2s both;
  position: relative;
  overflow: hidden;
}
.tip-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, var(--border-mid) 50%, transparent 100%);
}
.tip-icon-wrap { font-size:48rpx; line-height:1.3; flex-shrink: 0; margin-top: 2rpx; }
.tip-content { flex:1; }
.tip-label { font-size:20rpx; color:var(--accent3); font-weight:700; margin-bottom:6rpx; text-transform:uppercase; letter-spacing:3rpx; }
.tip-text { font-size:26rpx; color:var(--sub); line-height:1.8; }

/* ========== 快捷入口 ========== */
.quick-actions { display:flex; gap:16rpx; padding:12rpx 22rpx 0; }
.quick-btn {
  flex:1; display:flex; flex-direction:column; align-items:center; gap:14rpx;
  background:var(--card); border-radius:var(--radius-lg);
  padding:32rpx 10rpx 28rpx; box-shadow: var(--shadow-sm);
  transition: all var(--duration-normal) var(--ease-spring);
  border: 1rpx solid var(--border-light);
  animation: fadeInUp var(--duration-slow) var(--ease-out) both;
  position: relative;
  overflow: hidden;
}
.quick-btn::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, var(--border-mid) 50%, transparent 100%);
  opacity: 0;
  transition: opacity var(--duration-normal);
}
.quick-btn:hover::before { opacity: 1; }
.quick-btn:nth-child(1) { animation-delay: 0.22s; }
.quick-btn:nth-child(2) { animation-delay: 0.28s; }
.quick-btn:nth-child(3) { animation-delay: 0.34s; }
.quick-btn:hover { transform: translateY(-5rpx); box-shadow: var(--shadow-md); }
.quick-btn:active { transform: translateY(2rpx) scale(0.97); box-shadow: var(--shadow-sm); }
.quick-icon {
  width:88rpx; height:88rpx; border-radius:50%;
  background: var(--card2); display:flex; align-items:center; justify-content:center;
  font-size:42rpx;
  transition: transform var(--duration-normal) var(--ease-spring);
  border: 1rpx solid var(--border);
}
.quick-btn:hover .quick-icon { transform: scale(1.12) rotate(4deg); background: var(--card3); }
.quick-btn:active .quick-icon { transform: scale(0.90); }
.quick-label { font-size:24rpx; color:var(--text); font-weight:600; }