/* ========== 测试头部 ========== */
.test-header { text-align:center; padding:32rpx 40rpx 24rpx; }
.test-hero { font-size:80rpx; margin-bottom:16rpx; }
.test-title { font-size:38rpx; font-weight:800; color:var(--text); margin-bottom:8rpx; }
.test-sub { font-size:26rpx; color:var(--sub2); margin-bottom:24rpx; }

.test-progress { display:flex; align-items:center; gap:16rpx; justify-content:center; }
.progress-track { width:240rpx; height:8rpx; background:var(--border-light); border-radius:4rpx; overflow:hidden; }
.progress-fill-bpti { height:100%; background:linear-gradient(90deg, var(--accent), var(--accent-light)); border-radius:4rpx; transition:width 0.4s; }
.progress-text { font-size:24rpx; color:var(--sub2); font-weight:600; }

/* ========== 题目列表 ========== */
.q-list { padding:0 20rpx; }
.q-card {
  background:var(--card); border-radius:var(--radius-md);
  padding:28rpx; margin-bottom:16rpx;
  box-shadow:var(--shadow-sm);
  border:1rpx solid var(--border-light);
}
.q-number {
  display:inline-flex; align-items:center; justify-content:center;
  width:40rpx; height:40rpx; border-radius:50%;
  background:linear-gradient(135deg, var(--accent), var(--accent-dark));
  color:#fff;
  font-size:22rpx; font-weight:700; margin-bottom:12rpx;
  box-shadow:0 2rpx 8rpx rgba(126,200,80,0.25);
}
.q-text { font-size:30rpx; font-weight:600; color:var(--text); margin-bottom:20rpx; line-height:1.5; }
.q-options { display:flex; flex-direction:column; gap:12rpx; }
.q-option {
  padding:22rpx 24rpx; border-radius:var(--radius-sm);
  background:var(--card2); font-size:26rpx; color:var(--text);
  border:2rpx solid transparent; transition:all 0.2s;
  word-break:break-word; overflow-wrap:break-word;
}
.q-option:active { transform:scale(0.98); }
.q-option.active {
  border-color:var(--accent); background:rgba(126,200,80,0.08);
  font-weight:600;
}

/* ========== 提交按钮 ========== */
.submit-wrap { padding:20rpx; }
.btn-submit {
  width:100%; background:linear-gradient(135deg, var(--accent), var(--accent-dark)); color:#fff;
  border-radius:var(--radius-full); padding:24rpx;
  font-size:32rpx; font-weight:600; border:none;
  box-shadow:0 6rpx 24rpx rgba(126,200,80,0.30);
}
.btn-submit:active { transform:scale(0.97); }

/* ========== 结果 ========== */
.result-badge {
  text-align:center; padding:16rpx 0 8rpx;
  font-size:28rpx; color:var(--sub2); font-weight:500;
}
.persona-wrap { padding:0 20rpx; }
.persona-card {
  position:relative; text-align:center; padding:40rpx 36rpx 36rpx;
  border-radius:var(--radius-lg); overflow:hidden;
  background:linear-gradient(160deg, #fafff5 0%, #f0fae8 40%, #f5fff0 100%);
  box-shadow:var(--shadow-md); margin-bottom:16rpx;
}
.theme-dark .persona-card {
  background:linear-gradient(160deg, #1e2418 0%, #1a2216 40%, #1c2218 100%);
}
.persona-icon { font-size:100rpx; margin-bottom:16rpx; }
.persona-name { font-size:40rpx; font-weight:800; color:var(--text); margin-bottom:12rpx; }
.persona-desc { font-size:26rpx; color:var(--sub); line-height:1.8; }

.poo-code { display:inline-flex; align-items:center; gap:6rpx; margin:0 auto 16rpx; padding:4rpx 16rpx; background:rgba(0,0,0,0.04); border-radius:var(--radius-full); }
.theme-dark .poo-code { background:rgba(255,255,255,0.06); }
.poo-label { font-size:20rpx; font-weight:600; color:var(--sub2); letter-spacing:1rpx; }
.poo-value { font-size:26rpx; font-weight:800; color:var(--accent); letter-spacing:2rpx; }

/* Color themes for persona cards (copy from personality page) */
.persona-card.morning_elf { background:linear-gradient(160deg, #fff8e6, #fff3d6, #fffbe6); }
.persona-card.golden { background:linear-gradient(160deg, #f6fbf0, #eef7e0, #f4f9ec); }
.persona-card.speed { background:linear-gradient(160deg, #f4f8ff, #e8f0ff, #f0f4ff); }
.persona-card.thinker { background:linear-gradient(160deg, #f8f4ff, #f0e8ff, #f4f0ff); }
.persona-card.rainbow { background:linear-gradient(160deg, #fff4f8, #ffe8f0, #fff0f4); }
.persona-card.explorer { background:linear-gradient(160deg, #f4fff8, #e8fff0, #f0fff4); }

/* ========== 维度分析 ========== */
.dims-wrap { display:flex; flex-direction:column; gap:20rpx; }
.dim-row { display:flex; align-items:center; gap:14rpx; }
.dim-header { width:80rpx; display:flex; flex-direction:column; align-items:center; gap:2rpx; }
.dim-name { font-size:24rpx; color:var(--text); font-weight:500; }
.dim-bar-wrap { flex:1; height:18rpx; background:var(--border-light); border-radius:9rpx; overflow:hidden; }
.dim-bar { height:100%; border-radius:9rpx; transition:width 0.6s ease-out; min-width:4rpx; }
.dim-bar-time { background:linear-gradient(90deg, #ffb347, #ff8c00); }
.dim-bar-speed { background:linear-gradient(90deg, #4ecdc4, #44b09e); }
.dim-bar-type { background:linear-gradient(90deg, #a78bfa, #7c3aed); }
.dim-bar-rhythm { background:linear-gradient(90deg, #f97373, #e74c3c); }
.dim-label { width:60rpx; font-size:22rpx; color:var(--sub2); text-align:right; }

/* ========== 核心优势 + 建议 ========== */
.strength-body { font-size:28rpx; color:var(--sub); line-height:1.9; }
.advice-card { margin:0 0 16rpx; padding:24rpx 28rpx; background:var(--card); border-radius:var(--radius-md); box-shadow:var(--shadow-sm); }
.advice-title { font-size:30rpx; font-weight:600; margin-bottom:14rpx; color:var(--text); }
.advice-body { font-size:28rpx; color:var(--sub); line-height:1.8; }

/* ========== 结果按钮 ========== */
.result-actions { margin:24rpx 0 40rpx; display:flex; flex-direction:column; gap:16rpx; }
.btn-share-result {
  width:100%; background:linear-gradient(135deg, var(--accent), var(--accent-dark)); color:#fff; border-radius:var(--radius-full);
  padding:24rpx; font-size:30rpx; font-weight:600; border:none;
  box-shadow:0 6rpx 20rpx rgba(126,200,80,0.25);
}
.btn-share-result:active { transform:scale(0.97); }
.btn-retry {
  width:100%; background:var(--card); color:var(--text); border-radius:var(--radius-full);
  padding:24rpx; font-size:30rpx; font-weight:600; border:2rpx solid var(--border-light);
}
.btn-retry:active { background:var(--card2); transform:scale(0.97); }
